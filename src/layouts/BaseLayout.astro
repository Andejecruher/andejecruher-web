---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SEO from '../components/SEO.astro';
import { getLang } from '../i18n/utils';
import type { SeoProps } from '../seo/types';

interface Props {
  lang?: string;
  seo?: SeoProps;
}

const lang = Astro.props.lang ?? getLang(Astro.url.pathname);
const seo = (Astro.props.seo ?? Astro.props) as SeoProps;
---

<!doctype html>
<html lang={lang} class="scroll-smooth theme-dark" data-theme="dark">
  <head>
    <script is:inline>
      (function () {
        try {
          var storageKey = 'andejecruher-theme';
          var storedTheme = window.localStorage.getItem(storageKey);
          var preferredTheme =
            storedTheme === 'light' || storedTheme === 'dark'
              ? storedTheme
              : window.matchMedia('(prefers-color-scheme: light)').matches
                ? 'light'
                : 'dark';
          var root = document.documentElement;
          root.dataset.theme = preferredTheme;
          root.classList.toggle('theme-light', preferredTheme === 'light');
          root.classList.toggle('theme-dark', preferredTheme === 'dark');
        } catch (error) {
          document.documentElement.dataset.theme = 'dark';
          document.documentElement.classList.add('theme-dark');
        }
      })();
    </script>
    <ViewTransitions />
    <SEO {...seo} lang={lang} />
    <link rel="alternate" type="application/rss+xml" title="Andejecruher Blog" href="/rss.xml" />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">{lang === 'en' ? 'Skip to main content' : 'Saltar al contenido principal'}</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    <script>
      document.addEventListener('astro:page-load', () => {
        document.querySelectorAll<HTMLImageElement>('.blog-card-media img').forEach((image) => {
          image.addEventListener('error', () => { image.style.display = 'none'; }, { once: true });
        });
      });
    </script>
  </body>
</html>
