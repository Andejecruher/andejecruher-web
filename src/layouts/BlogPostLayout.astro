---
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import SEO from '../components/SEO.astro';
import { getLang } from '../i18n/utils';
import { seoFromBlogPost } from '../seo/utils';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  image?: string;
  tags?: string[];
  category?: string;
  canonical?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author,
  image,
  tags = [],
  category,
  canonical,
} = Astro.props;

const lang = getLang(Astro.url.pathname);

const seoProps = seoFromBlogPost({
  title,
  description,
  pubDate,
  updatedDate,
  author,
  image,
  tags,
  category,
  canonical,
  lang,
});
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <SEO {...seoProps} />
  </head>
  <body>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
