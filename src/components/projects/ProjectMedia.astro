---
interface Props {
  name: string;
  image?: string;
  alt?: string;
  loading?: 'lazy' | 'eager';
  className?: string;
  initialsSizeClass?: string;
}

const {
  name,
  image,
  alt,
  loading = 'lazy',
  className = '',
  initialsSizeClass = 'text-3xl md:text-4xl',
} = Astro.props as Props;

const projectName = name.trim() || 'Project';
const imageAlt = alt ?? `${projectName} project preview`;
const hasImage = typeof image === 'string' && image.trim().length > 0;
const fallbackInitials =
  projectName
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((word) => word.charAt(0).toUpperCase())
    .join('') || 'PR';
const mediaClass = [
  'relative w-full overflow-hidden rounded-2xl border border-white/10 bg-slate-950/70 shadow-[0_18px_36px_rgba(2,6,23,0.35)]',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div class={mediaClass}>
  <div class="aspect-[16/9] w-full">
    {
      hasImage && (
        <img
          src={image}
          alt={imageAlt}
          width="1280"
          height="720"
          loading={loading}
          class="h-full w-full object-cover"
          onerror="this.classList.add('hidden');const fallback=this.parentElement?.querySelector('[data-media-fallback]');if(fallback){fallback.classList.remove('hidden');}"
        />
      )
    }

    <div
      data-media-fallback
      role="img"
        aria-label={imageAlt}
        class:list={[
          'relative flex h-full w-full items-center justify-center bg-[radial-gradient(circle_at_top,#134e4a_0%,#111827_42%,#020617_100%)]',
          hasImage && 'hidden',
        ]}
      >
      <span class={`font-semibold tracking-[0.2em] text-cyan-100/70 ${initialsSizeClass}`}>{fallbackInitials}</span>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 bg-[linear-gradient(135deg,rgba(45,212,191,0.12),transparent_42%,rgba(14,116,144,0.1))]"
      ></div>
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 opacity-20 [background-image:linear-gradient(to_right,rgba(6,182,212,0.12)_1px,transparent_1px),linear-gradient(to_bottom,rgba(6,182,212,0.1)_1px,transparent_1px)] [background-size:28px_28px]"
      ></div>
    </div>
  </div>

  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,rgba(2,6,23,0.04)_0%,rgba(2,6,23,0.18)_100%)]"
  ></div>
</div>
