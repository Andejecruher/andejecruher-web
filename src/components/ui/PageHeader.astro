---
interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
}

const { badge, title, subtitle } = Astro.props;
---

<section class="relative overflow-hidden px-4 pt-28 pb-20 md:pt-32 md:pb-24 section-bg-page-header">
  <div class="absolute inset-x-0 bottom-0 h-px divider-accent opacity-70" aria-hidden="true"></div>

  <div class="max-w-6xl mx-auto text-center relative z-10">
    {
      badge && (
        <span class="badge badge-accent mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-current inline-block" aria-hidden="true" />
          {badge}
        </span>
      )
    }
    <h1 class="section-heading text-balance mb-4 font-bold text-heading">
      {title}
    </h1>
    {
      subtitle && (
        <p class="text-base md:text-lg leading-relaxed max-w-3xl mx-auto text-body-secondary">
          {subtitle}
        </p>
      )
    }
    <span class="section-heading-line mx-auto mt-7" aria-hidden="true"></span>
  </div>
</section>
