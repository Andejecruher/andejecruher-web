---
interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
}

const { badge, title, subtitle } = Astro.props;
---

<section class="relative py-20 px-4 overflow-hidden section-bg-page-header">
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-48 opacity-20 pointer-events-none glow-radial-subtle"
    aria-hidden="true"
  >
  </div>

  <div class="max-w-6xl mx-auto text-center relative z-10">
    {
      badge && (
        <span class="badge badge-accent mb-4">
          <span class="w-1.5 h-1.5 rounded-full bg-current inline-block" aria-hidden="true" />
          {badge}
        </span>
      )
    }
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-balance mb-4 text-heading">
      {title}
    </h1>
    {
      subtitle && (
        <p class="text-base md:text-lg leading-relaxed max-w-2xl mx-auto text-body-secondary">
          {subtitle}
        </p>
      )
    }
  </div>
</section>
