---
interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { badge, title, subtitle, align = 'center' } = Astro.props;
const alignClass = align === 'center' ? 'text-center items-center' : 'text-left items-start';
const lineClass =
  align === 'center' ? 'section-heading-line' : 'section-heading-line section-heading-line-left';
---

<div class={`flex flex-col gap-3 mb-12 md:mb-14 ${alignClass}`}>
  {
    badge && (
      <span class="badge badge-accent w-fit">
        <span class="w-1.5 h-1.5 rounded-full bg-current inline-block" aria-hidden="true" />
        {badge}
      </span>
    )
  }
  <h2 class="section-heading font-bold text-heading text-balance">
    {title}
  </h2>
  {
    subtitle && (
      <p class="text-base md:text-lg leading-relaxed max-w-2xl text-body-secondary">{subtitle}</p>
    )
  }
  <span class={lineClass} aria-hidden="true"></span>
</div>
