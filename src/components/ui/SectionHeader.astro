---
interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { badge, title, subtitle, align = 'center' } = Astro.props;
const alignClass = align === 'center' ? 'text-center items-center' : 'text-left items-start';
---

<div class={`flex flex-col gap-3 mb-12 ${alignClass}`}>
  {
    badge && (
      <span class="badge badge-accent w-fit">
        <span class="w-1.5 h-1.5 rounded-full bg-current inline-block" aria-hidden="true" />
        {badge}
      </span>
    )
  }
  <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-heading">
    {title}
  </h2>
  {subtitle && <p class="text-base leading-relaxed max-w-xl text-body-secondary">{subtitle}</p>}
</div>
