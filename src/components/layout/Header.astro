---
import { navItems } from '../../data/navigation';
import { SUPPORTED_LANGS } from '../../i18n/config';
import { getLang, useTranslations } from '../../i18n/utils';
import { localizePath } from '../../i18n/routing';
import logoLight from '../../assets/logo-light.png';
import logoDark from '../../assets/logo-dark.png';

interface Props {
  mode?: 'fixed' | 'static';
}

const { mode = 'fixed' } = Astro.props;
const headerPositionClass = mode === 'static' ? 'relative z-30' : 'fixed top-0 left-0 right-0 z-50';
const currentPath = Astro.url.pathname;
const lang = getLang(currentPath);
const t = useTranslations(lang);
const homeHref = localizePath('/', lang);
const contactHref = localizePath('/contacto', lang);
const languageOptions = SUPPORTED_LANGS.map((optionLang) => ({
  lang: optionLang,
  label: t(`nav:language-${optionLang}`),
  shortLabel: t(`nav:language-${optionLang}-short`),
  href: localizePath(currentPath, optionLang),
  active: optionLang === lang,
}));

function normalizePath(path: string): string {
  if (path !== '/' && path.endsWith('/')) return path.slice(0, -1);
  return path;
}

function isActive(href: string): boolean {
  const normalizedCurrentPath = normalizePath(currentPath);
  const normalizedHref = normalizePath(href);

  if (normalizedHref === normalizePath(homeHref)) {
    return normalizedCurrentPath === normalizedHref;
  }

  return (
    normalizedCurrentPath === normalizedHref ||
    normalizedCurrentPath.startsWith(`${normalizedHref}/`)
  );
}
---

<header data-site-header data-header-mode={mode} class={`${headerPositionClass} px-3 py-3 sm:px-4`}>
  <nav
    class="nav-shell nav-shell-main max-w-7xl mx-auto flex items-center justify-between gap-3 px-3 py-2.5 sm:px-5 lg:px-6"
    aria-label={t('nav:aria-label')}
  >
    <!-- Logo -->
    <a href={homeHref} class="site-logo flex items-center flex-shrink-0" aria-label="Andejecruher">
      <img
        src={logoDark.src}
        alt="Andejecruher Logo"
        width={logoDark.width}
        height={logoDark.height}
        data-site-logo
        data-theme-logo
        data-logo-light-src={logoLight.src}
        data-logo-dark-src={logoDark.src}
        data-logo-light-width={String(logoLight.width)}
        data-logo-dark-width={String(logoDark.width)}
        data-logo-light-height={String(logoLight.height)}
        data-logo-dark-height={String(logoDark.height)}
        class="h-12 w-auto max-w-[190px] object-contain sm:h-14 sm:max-w-[230px] lg:h-12 xl:h-14"
      />
    </a>

    <!-- Desktop nav -->
    <ul class="nav-list hidden lg:flex items-center gap-1" role="list">
      {
        navItems.map((item) => {
          const href = localizePath(item.href, lang);
          const active = isActive(href);
          return (
            <li>
              <a
                href={href}
                class={`nav-link ${active ? 'nav-link-active' : ''}`}
                aria-current={active ? 'page' : undefined}
              >
                {t(`nav:item-${item.key}`)}
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="nav-actions flex items-center gap-2">
      <!-- Desktop controls -->
      <div
        class="language-switcher hidden lg:inline-flex"
        role="group"
        aria-label={t('nav:language-switcher-label')}
      >
        {
          languageOptions.map((option) => (
            <a
              href={option.href}
              class={`language-switcher__link ${option.active ? 'language-switcher__link--active' : ''}`}
              lang={option.lang}
              hreflang={option.lang}
              aria-label={t('nav:language-switch-aria', { language: option.label })}
              aria-current={option.active ? 'true' : undefined}
            >
              {option.shortLabel}
            </a>
          ))
        }
      </div>

      <button
        class="control-btn hidden lg:inline-flex"
        type="button"
        aria-label={t('nav:theme-toggle-label')}
        aria-pressed="false"
        data-theme-toggle
        data-theme-label-dark={t('nav:theme-toggle-dark')}
        data-theme-label-light={t('nav:theme-toggle-light')}
      >
        <svg
          class="theme-icon theme-icon-sun"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
          ></path>
        </svg>
        <svg
          class="theme-icon theme-icon-moon"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      <!-- CTA -->
      <a href={contactHref} class="btn btn-secondary btn-sm nav-cta hidden lg:inline-flex">
        {t('nav:cta-connect')}
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class="hamburger-btn lg:hidden inline-flex flex-col items-center justify-center gap-1.5"
        aria-label={t('nav:menu-open')}
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-label-open={t('nav:menu-open')}
        data-label-close={t('nav:menu-close')}
      >
        <span class="block h-px w-6 bg-current transition-all duration-300" id="bar1"></span>
        <span class="block h-px w-6 bg-current transition-all duration-300" id="bar2"></span>
        <span class="block h-px w-4 bg-current transition-all duration-300" id="bar3"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="nav-shell mobile-menu-shell mx-auto mt-2 max-w-7xl overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0"
    aria-hidden="true"
  >
    <div class="flex flex-col gap-4 p-4 sm:p-5">
      <ul class="flex flex-col gap-1" role="list" aria-label={t('nav:aria-label')}>
        {
          navItems.map((item) => {
            const href = localizePath(item.href, lang);
            const active = isActive(href);
            return (
              <li>
                <a
                  href={href}
                  class={`mobile-menu-link block min-h-11 px-4 py-3 text-sm font-semibold rounded-xl transition-colors duration-200 ${
                    active
                      ? 'nav-link-mobile-active'
                      : 'text-body-secondary link-muted brand-hover-surface'
                  }`}
                  aria-current={active ? 'page' : undefined}
                >
                  {t(`nav:item-${item.key}`)}
                </a>
              </li>
            );
          })
        }
      </ul>

      <div class="grid gap-3 border-t divider pt-4">
        <div
          class="language-switcher w-full justify-center"
          role="group"
          aria-label={t('nav:language-switcher-label')}
        >
          {
            languageOptions.map((option) => (
              <a
                href={option.href}
                class={`language-switcher__link flex-1 ${option.active ? 'language-switcher__link--active' : ''}`}
                lang={option.lang}
                hreflang={option.lang}
                aria-label={t('nav:language-switch-aria', { language: option.label })}
                aria-current={option.active ? 'true' : undefined}
              >
                {option.label}
              </a>
            ))
          }
        </div>

        <button
          class="control-btn mobile-theme-btn gap-2 px-4 font-semibold"
          type="button"
          aria-label={t('nav:theme-toggle-label')}
          aria-pressed="false"
          data-theme-toggle
          data-theme-label-dark={t('nav:theme-toggle-dark')}
          data-theme-label-light={t('nav:theme-toggle-light')}
        >
          <span class="relative inline-flex h-5 w-5 items-center justify-center" aria-hidden="true">
            <svg
              class="theme-icon theme-icon-sun"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="4"></circle>
              <path
                d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
              ></path>
            </svg>
            <svg
              class="theme-icon theme-icon-moon"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </span>
          <span>{t('nav:theme-toggle-label')}</span>
        </button>

        <a
          href={contactHref}
          class="mobile-menu-link btn btn-secondary btn-sm w-full justify-center"
        >
          {t('nav:cta-connect')}
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  type CleanupFn = () => void;

  interface HeaderWindow extends Window {
    __headerInitCleanup__?: CleanupFn;
  }

  function getElementById<T extends HTMLElement>(id: string) {
    return (document.getElementById(id) as T | undefined) ?? undefined;
  }

  function initHeader() {
    const cleanupBucket: CleanupFn[] = [];
    const pushCleanup = (cleanup: CleanupFn) => cleanupBucket.push(cleanup);
    const cleanupAll = () => cleanupBucket.splice(0).forEach((cleanup) => cleanup());

    const toggle = getElementById<HTMLButtonElement>('menu-toggle');
    const menu = getElementById<HTMLDivElement>('mobile-menu');
    const bar1 = getElementById<HTMLSpanElement>('bar1');
    const bar2 = getElementById<HTMLSpanElement>('bar2');
    const bar3 = getElementById<HTMLSpanElement>('bar3');
    const headerEl = document.querySelector<HTMLElement>('[data-site-header]');

    if (!toggle || !menu || !headerEl) {
      return cleanupAll;
    }

    const signalController = new AbortController();
    const { signal } = signalController;
    pushCleanup(() => signalController.abort());

    let open = false;

    function closeMenu() {
      if (!open) return;

      open = false;
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', toggle.dataset.labelOpen ?? 'Open menu');
      menu?.setAttribute('aria-hidden', 'true');
      if (menu) {
        menu.style.maxHeight = '0';
        menu.style.opacity = '0';
      }
      if (bar1) bar1.style.transform = '';
      if (bar2) bar2.style.opacity = '1';
      if (bar3) {
        bar3.style.transform = '';
        bar3.style.width = '16px';
      }
    }

    function openMenu() {
      if (open) return;

      open = true;
      toggle?.setAttribute('aria-expanded', 'true');
      toggle?.setAttribute('aria-label', toggle.dataset.labelClose ?? 'Close menu');
      menu?.setAttribute('aria-hidden', 'false');
      if (menu) {
        menu.style.maxHeight = `${menu.scrollHeight}px`;
        menu.style.opacity = '1';
      }
      if (bar1) bar1.style.transform = 'translateY(6px) rotate(45deg)';
      if (bar2) bar2.style.opacity = '0';
      if (bar3) {
        bar3.style.transform = 'translateY(-6px) rotate(-45deg)';
        bar3.style.width = '24px';
      }
    }

    toggle.addEventListener(
      'click',
      () => {
        if (open) {
          closeMenu();
        } else {
          openMenu();
        }
      },
      { signal },
    );

    document.querySelectorAll('.mobile-menu-link').forEach((link) => {
      link.addEventListener('click', () => closeMenu(), { signal });
    });

    document.addEventListener(
      'click',
      (event) => {
        if (
          open &&
          !toggle.contains(event.target as Node) &&
          !menu.contains(event.target as Node)
        ) {
          closeMenu();
        }
      },
      { signal },
    );

    document.addEventListener(
      'keydown',
      (event) => {
        if (event.key === 'Escape') {
          closeMenu();
        }
      },
      { signal },
    );

    window.addEventListener(
      'resize',
      () => {
        if (open) {
          menu.style.maxHeight = `${menu.scrollHeight}px`;
        }
      },
      { signal },
    );

    const themeToggles = Array.from(document.querySelectorAll<HTMLElement>('[data-theme-toggle]'));
    const storageKey = 'andejecruher-theme';

    function getPreferredTheme() {
      const storedTheme = window.localStorage.getItem(storageKey);
      if (storedTheme === 'light' || storedTheme === 'dark') return storedTheme;
      return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    }

    function applyTheme(theme: 'light' | 'dark') {
      const root = document.documentElement;
      root.dataset.theme = theme;
      root.classList.toggle('theme-light', theme === 'light');
      root.classList.toggle('theme-dark', theme === 'dark');

      document.querySelectorAll<HTMLImageElement>('[data-theme-logo]').forEach((logo) => {
        const nextLogoSrc =
          theme === 'light' ? logo.dataset.logoLightSrc : logo.dataset.logoDarkSrc;
        const nextLogoWidth =
          theme === 'light' ? logo.dataset.logoLightWidth : logo.dataset.logoDarkWidth;
        const nextLogoHeight =
          theme === 'light' ? logo.dataset.logoLightHeight : logo.dataset.logoDarkHeight;

        if (nextLogoSrc) {
          logo.src = nextLogoSrc;
        }
        if (nextLogoWidth) {
          logo.width = Number.parseInt(nextLogoWidth, 10);
        }
        if (nextLogoHeight) {
          logo.height = Number.parseInt(nextLogoHeight, 10);
        }
      });

      themeToggles.forEach((themeToggle) => {
        themeToggle.setAttribute('aria-pressed', String(theme === 'dark'));
        themeToggle.setAttribute(
          'aria-label',
          theme === 'dark'
            ? (themeToggle.dataset.themeLabelLight ?? 'Switch to light theme')
            : (themeToggle.dataset.themeLabelDark ?? 'Switch to dark theme'),
        );
      });
    }

    const preferredThemeMedia = window.matchMedia('(prefers-color-scheme: light)');
    const onPreferredThemeChange = () => {
      const storedTheme = window.localStorage.getItem(storageKey);
      if (storedTheme !== 'light' && storedTheme !== 'dark') {
        applyTheme(getPreferredTheme());
      }
    };

    if (typeof preferredThemeMedia.addEventListener === 'function') {
      preferredThemeMedia.addEventListener('change', onPreferredThemeChange);
      pushCleanup(() => preferredThemeMedia.removeEventListener('change', onPreferredThemeChange));
    } else {
      preferredThemeMedia.addListener(onPreferredThemeChange);
      pushCleanup(() => preferredThemeMedia.removeListener(onPreferredThemeChange));
    }

    applyTheme(document.documentElement.dataset.theme === 'light' ? 'light' : getPreferredTheme());

    themeToggles.forEach((themeToggle) => {
      themeToggle.addEventListener(
        'click',
        () => {
          const currentTheme =
            document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
          const nextTheme: 'light' | 'dark' = currentTheme === 'dark' ? 'light' : 'dark';
          window.localStorage.setItem(storageKey, nextTheme);
          applyTheme(nextTheme);
        },
        { signal },
      );
    });

    const updateHeaderHeight = () => {
      const height = headerEl.getBoundingClientRect().height;
      document.documentElement.style.setProperty('--site-header-height', `${Math.ceil(height)}px`);
    };

    updateHeaderHeight();
    window.addEventListener('load', updateHeaderHeight, { once: true, signal });
    window.addEventListener('resize', updateHeaderHeight, { signal });

    if ('ResizeObserver' in window) {
      const observer = new ResizeObserver(updateHeaderHeight);
      observer.observe(headerEl);
      pushCleanup(() => observer.disconnect());
    }

    pushCleanup(() => closeMenu());
    return cleanupAll;
  }

  const headerWindow = window as HeaderWindow;

  const runHeaderInit = () => {
    headerWindow.__headerInitCleanup__?.();
    headerWindow.__headerInitCleanup__ = initHeader();
  };

  runHeaderInit();
  document.addEventListener('astro:page-load', runHeaderInit);
</script>
