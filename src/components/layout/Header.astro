---
import { navItems } from '../../data/navigation';
import { getLang, useTranslations } from '../../i18n/utils';
import { localizePath } from '../../i18n/routing';

const currentPath = Astro.url.pathname;
const lang = getLang(currentPath);
const t = useTranslations(lang);
const homeHref = localizePath('/', lang);
const contactHref = localizePath('/contacto', lang);

function normalizePath(path: string): string {
  if (path !== '/' && path.endsWith('/')) return path.slice(0, -1);
  return path;
}

function isActive(href: string): boolean {
  const normalizedCurrentPath = normalizePath(currentPath);
  const normalizedHref = normalizePath(href);

  if (normalizedHref === normalizePath(homeHref)) {
    return normalizedCurrentPath === normalizedHref;
  }

  return (
    normalizedCurrentPath === normalizedHref ||
    normalizedCurrentPath.startsWith(`${normalizedHref}/`)
  );
}
---

<header class="fixed top-0 left-0 right-0 z-50 px-4 py-3">
  <nav
    class="nav-shell max-w-6xl mx-auto flex items-center justify-between px-5 py-3"
    aria-label={t('nav:aria-label')}
  >
    <!-- Logo -->
    <a href={homeHref} class="flex items-center gap-3 flex-shrink-0" aria-label="Andejecruher">
      <img
        src="https://hebbkx1anhila5yf.public.blob.vercel-storage.com/logo-light-SN0TQe1GiqMYkHyYngYcVSY4JeDgHC.png"
        alt="Andejecruher Logo"
        width="180"
        height="44"
        class="h-9 w-auto object-contain"
      />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-1" role="list">
      {
        navItems.map((item) => {
          const href = localizePath(item.href, lang);
          const active = isActive(href);
          return (
            <li>
              <a
                href={href}
                class={`nav-link ${active ? 'nav-link-active' : ''}`}
                aria-current={active ? 'page' : undefined}
              >
                {t(`nav:item-${item.key}`)}
              </a>
            </li>
          );
        })
      }
    </ul>

    <!-- CTA -->
    <div class="hidden lg:flex items-center">
      <a href={contactHref} class="btn btn-secondary btn-sm">
        {t('nav:cta-connect')}
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="lg:hidden flex flex-col gap-1.5 p-2 rounded-lg transition-colors text-body-muted hover:text-brand-primary"
      aria-label={t('nav:menu-open')}
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block h-px w-6 bg-current transition-all duration-300" id="bar1"></span>
      <span class="block h-px w-6 bg-current transition-all duration-300" id="bar2"></span>
      <span class="block h-px w-4 bg-current transition-all duration-300" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="nav-shell lg:hidden mt-2 overflow-hidden transition-all duration-300 max-h-0 opacity-0"
    aria-hidden="true"
  >
    <ul class="flex flex-col p-4 gap-1" role="list">
      {
        navItems.map((item) => {
          const href = localizePath(item.href, lang);
          const active = isActive(href);
          return (
            <li>
              <a
                href={href}
                class={`block px-4 py-3 text-sm font-medium rounded-xl transition-colors duration-200 ${
                  active
                    ? 'nav-link-mobile-active'
                    : 'text-body-secondary hover:text-brand-primary brand-hover-surface'
                }`}
                aria-current={active ? 'page' : undefined}
              >
                {t(`nav:item-${item.key}`)}
              </a>
            </li>
          );
        })
      }
      <li class="pt-2 border-t divider mt-2">
        <a href={contactHref} class="btn btn-secondary btn-sm w-full justify-center mt-1">
          {t('nav:cta-connect')}
        </a>
      </li>
    </ul>
  </div>
</header>

<!-- Spacer -->
<div class="h-20" aria-hidden="true"></div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    toggle.setAttribute('aria-expanded', String(open));
    menu?.setAttribute('aria-hidden', String(!open));

    if (open) {
      menu!.style.maxHeight = menu!.scrollHeight + 'px';
      menu!.style.opacity = '1';
      bar1!.style.transform = 'translateY(6px) rotate(45deg)';
      bar2!.style.opacity = '0';
      bar3!.style.transform = 'translateY(-6px) rotate(-45deg)';
      bar3!.style.width = '24px';
    } else {
      menu!.style.maxHeight = '0';
      menu!.style.opacity = '0';
      bar1!.style.transform = '';
      bar2!.style.opacity = '1';
      bar3!.style.transform = '';
      bar3!.style.width = '16px';
    }
  });

  document.addEventListener('click', (e) => {
    if (open && !toggle?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      toggle?.click();
    }
  });
</script>
