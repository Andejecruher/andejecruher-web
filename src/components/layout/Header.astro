---
import { navItems } from '../../data/navigation';
import { SUPPORTED_LANGS } from '../../i18n/config';
import { getLang, useTranslations } from '../../i18n/utils';
import { localizePath } from '../../i18n/routing';

const currentPath = Astro.url.pathname;
const lang = getLang(currentPath);
const t = useTranslations(lang);
const homeHref = localizePath('/', lang);
const contactHref = localizePath('/contacto', lang);
const languageOptions = SUPPORTED_LANGS.map((optionLang) => ({
  lang: optionLang,
  label: t(`nav:language-${optionLang}`),
  shortLabel: t(`nav:language-${optionLang}-short`),
  href: localizePath(currentPath, optionLang),
  active: optionLang === lang,
}));

function normalizePath(path: string): string {
  if (path !== '/' && path.endsWith('/')) return path.slice(0, -1);
  return path;
}

function isActive(href: string): boolean {
  const normalizedCurrentPath = normalizePath(currentPath);
  const normalizedHref = normalizePath(href);

  if (normalizedHref === normalizePath(homeHref)) {
    return normalizedCurrentPath === normalizedHref;
  }

  return (
    normalizedCurrentPath === normalizedHref ||
    normalizedCurrentPath.startsWith(`${normalizedHref}/`)
  );
}
---

<header class="fixed top-0 left-0 right-0 z-50 px-4 py-3">
  <nav
    class="nav-shell max-w-6xl mx-auto flex items-center justify-between gap-3 px-4 sm:px-5 py-3"
    aria-label={t('nav:aria-label')}
  >
    <!-- Logo -->
    <a href={homeHref} class="flex items-center gap-3 flex-shrink-0" aria-label="Andejecruher">
      <img
        src="https://hebbkx1anhila5yf.public.blob.vercel-storage.com/logo-light-SN0TQe1GiqMYkHyYngYcVSY4JeDgHC.png"
        alt="Andejecruher Logo"
        width="180"
        height="44"
        class="h-9 w-auto object-contain"
      />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-1" role="list">
      {
        navItems.map((item) => {
          const href = localizePath(item.href, lang);
          const active = isActive(href);
          return (
            <li>
              <a
                href={href}
                class={`nav-link ${active ? 'nav-link-active' : ''}`}
                aria-current={active ? 'page' : undefined}
              >
                {t(`nav:item-${item.key}`)}
              </a>
            </li>
          );
        })
      }
    </ul>

    <div class="flex items-center gap-2">
      <!-- Global controls -->
      <div
        class="language-switcher hidden sm:inline-flex"
        role="group"
        aria-label={t('nav:language-switcher-label')}
      >
        {
          languageOptions.map((option) => (
            <a
              href={option.href}
              class={`language-switcher__link ${option.active ? 'language-switcher__link--active' : ''}`}
              lang={option.lang}
              hreflang={option.lang}
              aria-label={t('nav:language-switch-aria', { language: option.label })}
              aria-current={option.active ? 'true' : undefined}
            >
              {option.shortLabel}
            </a>
          ))
        }
      </div>

      <button
        id="theme-toggle"
        class="control-btn"
        type="button"
        aria-label={t('nav:theme-toggle-label')}
        aria-pressed="false"
        data-theme-label-dark={t('nav:theme-toggle-dark')}
        data-theme-label-light={t('nav:theme-toggle-light')}
      >
        <svg class="theme-icon theme-icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
        </svg>
        <svg class="theme-icon theme-icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      <!-- CTA -->
      <a href={contactHref} class="btn btn-secondary btn-sm hidden lg:inline-flex">
        {t('nav:cta-connect')}
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class="lg:hidden flex flex-col gap-1.5 p-2 rounded-lg transition-colors text-body-muted hover:text-brand-primary"
        aria-label={t('nav:menu-open')}
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-label-open={t('nav:menu-open')}
        data-label-close={t('nav:menu-close')}
      >
        <span class="block h-px w-6 bg-current transition-all duration-300" id="bar1"></span>
        <span class="block h-px w-6 bg-current transition-all duration-300" id="bar2"></span>
        <span class="block h-px w-4 bg-current transition-all duration-300" id="bar3"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="nav-shell lg:hidden mt-2 overflow-hidden transition-all duration-300 max-h-0 opacity-0"
    aria-hidden="true"
  >
    <ul class="flex flex-col p-4 gap-1" role="list">
      {
        navItems.map((item) => {
          const href = localizePath(item.href, lang);
          const active = isActive(href);
          return (
            <li>
              <a
                href={href}
                class={`block px-4 py-3 text-sm font-medium rounded-xl transition-colors duration-200 ${
                  active
                    ? 'nav-link-mobile-active'
                    : 'text-body-secondary hover:text-brand-primary brand-hover-surface'
                }`}
                aria-current={active ? 'page' : undefined}
              >
                {t(`nav:item-${item.key}`)}
              </a>
            </li>
          );
        })
      }
      <li class="pt-3 border-t divider mt-2">
        <div
          class="language-switcher w-full justify-center"
          role="group"
          aria-label={t('nav:language-switcher-label')}
        >
          {
            languageOptions.map((option) => (
              <a
                href={option.href}
                class={`language-switcher__link flex-1 ${option.active ? 'language-switcher__link--active' : ''}`}
                lang={option.lang}
                hreflang={option.lang}
                aria-label={t('nav:language-switch-aria', { language: option.label })}
                aria-current={option.active ? 'true' : undefined}
              >
                {option.label}
              </a>
            ))
          }
        </div>
      </li>
      <li class="pt-2">
        <a href={contactHref} class="btn btn-secondary btn-sm w-full justify-center mt-1">
          {t('nav:cta-connect')}
        </a>
      </li>
    </ul>
  </div>
</header>

<!-- Spacer -->
<div class="h-20" aria-hidden="true"></div>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute(
      'aria-label',
      open ? toggle.dataset.labelClose ?? 'Close menu' : toggle.dataset.labelOpen ?? 'Open menu',
    );
    menu?.setAttribute('aria-hidden', String(!open));

    if (open) {
      if (menu) {
        menu.style.maxHeight = `${menu.scrollHeight}px`;
        menu.style.opacity = '1';
      }
      if (bar1) bar1.style.transform = 'translateY(6px) rotate(45deg)';
      if (bar2) bar2.style.opacity = '0';
      if (bar3) {
        bar3.style.transform = 'translateY(-6px) rotate(-45deg)';
        bar3.style.width = '24px';
      }
    } else {
      if (menu) {
        menu.style.maxHeight = '0';
        menu.style.opacity = '0';
      }
      if (bar1) bar1.style.transform = '';
      if (bar2) bar2.style.opacity = '1';
      if (bar3) {
        bar3.style.transform = '';
        bar3.style.width = '16px';
      }
    }
  });

  document.addEventListener('click', (e) => {
    if (open && !toggle?.contains(e.target as Node) && !menu?.contains(e.target as Node)) {
      toggle?.click();
    }
  });

  const themeToggle = document.getElementById('theme-toggle');
  const storageKey = 'andejecruher-theme';

  function getPreferredTheme() {
    const storedTheme = window.localStorage.getItem(storageKey);
    if (storedTheme === 'light' || storedTheme === 'dark') return storedTheme;
    return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
  }

  function applyTheme(theme) {
    const root = document.documentElement;
    root.dataset.theme = theme;
    root.classList.toggle('theme-light', theme === 'light');
    root.classList.toggle('theme-dark', theme === 'dark');
    themeToggle?.setAttribute('aria-pressed', String(theme === 'dark'));
    themeToggle?.setAttribute(
      'aria-label',
      theme === 'dark'
        ? themeToggle.dataset.themeLabelLight ?? 'Switch to light theme'
        : themeToggle.dataset.themeLabelDark ?? 'Switch to dark theme',
    );
  }

  applyTheme(getPreferredTheme());

  themeToggle?.addEventListener('click', () => {
    const currentTheme = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
    const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
    window.localStorage.setItem(storageKey, nextTheme);
    applyTheme(nextTheme);
  });

  window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', () => {
    const storedTheme = window.localStorage.getItem(storageKey);
    if (storedTheme !== 'light' && storedTheme !== 'dark') {
      applyTheme(getPreferredTheme());
    }
  });
</script>
