---
import isotipoDark from '../../../assets/isotipo-dark.png';
import isotipoLight from '../../../assets/isotipo.png';
import { getProfile } from '../../../data/profile';
import { localizePath } from '../../../i18n/routing';
import { getLang, useTranslations } from '../../../i18n/utils';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const profile = getProfile(lang);
const contactHref = localizePath('/contacto', lang);
---

<section class="section-spacing section-bg-primary">
  <div class="max-w-5xl mx-auto">
    <div class="card-elevated relative overflow-hidden px-6 py-10 md:px-12 md:py-12 text-center">
      <div class="relative z-10 max-w-3xl mx-auto">
        <div class="flex justify-center mb-6 opacity-30" aria-hidden="true">
          <img
            src={isotipoDark.src}
            alt=""
            width={isotipoDark.width}
            height={isotipoDark.height}
            data-theme-logo
            data-logo-light-src={isotipoLight.src}
            data-logo-dark-src={isotipoDark.src}
            data-logo-light-width={String(isotipoLight.width)}
            data-logo-dark-width={String(isotipoDark.width)}
            data-logo-light-height={String(isotipoLight.height)}
            data-logo-dark-height={String(isotipoDark.height)}
            class="w-14 h-14 object-contain"
          />
        </div>

        <span class="badge badge-accent mb-6">
          <span
            class="w-1.5 h-1.5 rounded-full bg-current inline-block animate-pulse"
            aria-hidden="true"></span>
          {t('cta:available-badge')}
        </span>

        <h2 class="section-heading font-bold text-balance mb-4 text-heading">
          {t('cta:heading')}
        </h2>

        <p class="text-base md:text-lg leading-relaxed mb-8 max-w-2xl mx-auto text-body-secondary">
          {t('cta:body')}
        </p>

        <div class="flex flex-wrap justify-center gap-3">
          <a href={contactHref} class="btn btn-primary">
            {t('cta:contact-btn')}
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
            >
              <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
          </a>
          <a href={`mailto:${profile.email}`} class="btn btn-outline-light">
            {profile.email}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
