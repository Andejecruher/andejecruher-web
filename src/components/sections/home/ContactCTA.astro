---
import { localizePath } from '../../../i18n/routing';
import { getLang, useTranslations } from '../../../i18n/utils';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const contactHref = localizePath('/contacto', lang);
---

<section class="py-24 px-4 section-bg-footer">
  <div class="max-w-3xl mx-auto text-center">
    <div class="flex justify-center mb-8 opacity-20" aria-hidden="true">
      <img
        src="https://hebbkx1anhila5yf.public.blob.vercel-storage.com/favicon-IIAIcMQqZWR250f9s2EFuIHjBdUhm9.png"
        alt=""
        width="80"
        height="80"
        class="w-16 h-16 object-contain"
      />
    </div>

    <span class="badge badge-accent mb-6">
      <span
        class="w-1.5 h-1.5 rounded-full bg-current inline-block animate-pulse"
        aria-hidden="true"></span>
      {t('cta:available-badge')}
    </span>

    <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-balance mb-4 text-heading">
      {t('cta:heading')}
    </h2>

    <p class="text-base leading-relaxed mb-8 max-w-xl mx-auto text-body-secondary">
      {t('cta:body')}
    </p>

    <div class="flex flex-wrap justify-center gap-3">
      <a href={contactHref} class="btn btn-primary">
        {t('cta:contact-btn')}
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
      <a href="mailto:andejecruher@gmail.com" class="btn btn-outline-light">
        andejecruher@gmail.com
      </a>
    </div>
  </div>
</section>
