---
import { getProjects, statusColors } from '../../../data/projects';
import { localizePath } from '../../../i18n/routing';
import { getLang, useTranslations } from '../../../i18n/utils';
import SectionHeader from '../../ui/SectionHeader.astro';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const projectsHref = localizePath('/proyectos', lang);
const featured = getProjects(lang)
  .filter((p) => p.featured)
  .slice(0, 3);
---

<section class="section-spacing section-bg-primary">
  <div class="max-w-6xl mx-auto">
    <SectionHeader
      badge={t('projects:featured-badge')}
      title={t('projects:featured-title')}
      subtitle={t('projects:featured-subtitle')}
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      {
        featured.map((project, i) => (
          <article
            class={`card card-elevated card-interactive p-6 md:p-7 flex flex-col gap-4 cursor-default animate-fade-in-up delay-${(i + 1) * 100}`}
          >
            <div class="flex items-center justify-between gap-3">
              <span class="text-xs font-mono text-body-muted">
                {t(`projects:category-${project.categoryKey}`)}
              </span>
              <span class={`badge badge-neutral self-start border ${statusColors[project.status]}`}>
                {t(`projects:status-${project.status}`)}
              </span>
            </div>

            <h3 class="text-lg font-semibold text-heading">{project.name}</h3>

            <p class="text-sm leading-relaxed flex-1 text-body-secondary">{project.description}</p>

            <div class="flex flex-wrap gap-1.5">
              {project.technologies.slice(0, 4).map((tech) => (
                <span class="chip">{tech}</span>
              ))}
            </div>
          </article>
        ))
      }
    </div>

    <div class="text-center">
      <a href={projectsHref} class="btn btn-secondary btn-sm">
        {t('projects:cta-all')}
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
