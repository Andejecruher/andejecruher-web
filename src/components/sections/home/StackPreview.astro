---
import TechChip from '@/components/ui/TechChip.astro';
import { capabilityMap } from '../../../data/stack';
import { localizePath } from '../../../i18n/routing';
import { getLang, useTranslations } from '../../../i18n/utils';
import SectionHeader from '../../ui/SectionHeader.astro';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const mainCapabilities = capabilityMap.slice(0, 3);
const stackHref = localizePath('/stack', lang);
---

<section class="section-spacing section-bg-secondary">
  <div class="max-w-6xl mx-auto">
    <SectionHeader
      badge={t('home:stack-preview-badge')}
      title={t('home:stack-preview-title')}
      subtitle={t('home:stack-preview-subtitle')}
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
      {
        mainCapabilities.map((capability, i) => (
          <article
            class={`card card-interactive p-6 md:p-7 flex flex-col gap-4 animate-fade-in-up delay-${(i + 1) * 100}`}
          >
            <h3 class="text-base font-semibold text-heading">
              {t(`stack:capability-${capability.key}-title`)}
            </h3>
            <div class="flex flex-wrap gap-2">
              {capability.technologies.map((technology) => (
                <TechChip label={technology} />
              ))}
            </div>
          </article>
        ))
      }
    </div>

    <div class="text-center">
      <a href={stackHref} class="btn btn-secondary btn-sm">
        {t('home:stack-preview-cta')}
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
