---
import TechChip from '@/components/ui/TechChip.astro';
import { getExperiences } from '../../../data/experience';
import { localizePath } from '../../../i18n/routing';
import { getLang, useTranslations } from '../../../i18n/utils';
import SectionHeader from '../../ui/SectionHeader.astro';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const preview = getExperiences(lang).slice(0, 2);
const experienceHref = localizePath('/experiencia', lang);
---

<section class="section-spacing section-bg-secondary">
  <div class="max-w-6xl mx-auto">
    <SectionHeader
      badge={t('experience:preview-badge')}
      title={t('experience:preview-title')}
      subtitle={t('experience:preview-subtitle')}
      align="left"
    />

    <div class="flex flex-col gap-6 mb-10">
      {
        preview.map((exp, i) => (
          <article
            class={`card card-interactive p-6 md:p-7 flex flex-col gap-4 animate-fade-in-up delay-${(i + 1) * 100}`}
          >
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
              <div>
                <h3 class="text-lg font-semibold text-heading">{exp.role}</h3>
                <p class="text-sm mt-1 text-accent">{exp.company}</p>
              </div>
              <div class="flex flex-col items-start sm:items-end gap-1">
                <span class="chip chip-accent">{exp.period}</span>
                <span class="text-xs text-body-muted">{exp.modality}</span>
              </div>
            </div>
            <p class="text-sm leading-relaxed text-body-secondary">{exp.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {exp.technologies.slice(0, 5).map((tech) => (
                <TechChip label={tech} />
              ))}
            </div>
          </article>
        ))
      }
    </div>

    <a href={experienceHref} class="inline-flex items-center gap-2 text-sm font-medium link-accent">
      {t('experience:preview-cta')}
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        aria-hidden="true"
      >
        <path d="M5 12h14M12 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>
</section>
