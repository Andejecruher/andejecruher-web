---
import isotipoDark from '../../../assets/isotipo-dark.png';
import isotipoLight from '../../../assets/isotipo.png';
import { getHeroHeadline } from '../../../data/heroHeadline';
import { getProfile } from '../../../data/profile';
import { stats } from '../../../data/stats';
import { localizePath } from '../../../i18n/routing';
import { getLang, useTranslations } from '../../../i18n/utils';
import TechChip from '../../ui/TechChip.astro';
import TypewriterText from '../../ui/TypewriterText.astro';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const profile = getProfile(lang);
const headline = getHeroHeadline(lang);
const projectsHref = localizePath('/proyectos', lang);
const CvLink = 'https://drive.google.com/file/d/1Zsi1j6PDrRT6vpBOTJF7uHYY7LehM4Rr/view?usp=sharing';

const techBadges = ['SaaS', 'Laravel', 'Python', 'Node.js', 'React'];
---

<section
  class="relative min-h-screen flex items-center overflow-hidden px-4 pb-16 section-bg-primary"
  style="padding-top: calc(var(--site-header-height, 3.5rem) + 1rem);"
  aria-label={t('hero:section-aria-label')}
>
  <!-- Circuit decoration -->
  <svg
    class="absolute top-0 right-0 opacity-5 pointer-events-none text-accent"
    width="600"
    height="600"
    viewBox="0 0 600 600"
    aria-hidden="true"
    fill="none"
  >
    <circle cx="300" cy="300" r="280" stroke="currentColor" stroke-width="0.5"></circle>
    <circle cx="300" cy="300" r="200" stroke="currentColor" stroke-width="0.5"></circle>
    <circle cx="300" cy="300" r="120" stroke="currentColor" stroke-width="0.5"></circle>
    <line x1="300" y1="20" x2="300" y2="580" stroke="currentColor" stroke-width="0.5"></line>
    <line x1="20" y1="300" x2="580" y2="300" stroke="currentColor" stroke-width="0.5"></line>
    <circle cx="300" cy="20" r="4" fill="currentColor"></circle>
    <circle cx="300" cy="580" r="4" fill="currentColor"></circle>
    <circle cx="20" cy="300" r="4" fill="currentColor"></circle>
    <circle cx="580" cy="300" r="4" fill="currentColor"></circle>
  </svg>

  <!-- Radial glow top-right -->
  <div
    class="absolute -top-16 right-0 w-[360px] h-[360px] opacity-[0.03] pointer-events-none glow-radial"
    aria-hidden="true"
  >
  </div>

  <div
    class="max-w-6xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative z-10"
  >
    <!-- Left: content -->
    <div class="flex flex-col gap-6 animate-fade-in-up">
      <!-- Available badge -->
      <div class="flex items-center gap-2 w-fit">
        <span class="badge badge-success uppercase tracking-widest">
          <span
            class="w-1.5 h-1.5 rounded-full animate-pulse inline-block flex-shrink-0 bg-current"
            aria-hidden="true"></span>
          {t('hero:available-badge')}
        </span>
      </div>

      <!-- Headline -->
      <h1
        class="text-4xl md:text-5xl xl:text-6xl font-bold tracking-tight leading-[1.1] text-heading"
      >
        <TypewriterText phrases={headline.line1Phrases} />
        <br />
        {headline.line2}
        <span class="text-accent"> {headline.line2Accent}</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-base md:text-lg leading-relaxed max-w-lg text-body-secondary">
        {profile.description}
      </p>

      <!-- Tech badges -->
      <div class="flex flex-wrap gap-2.5" role="list" aria-label={t('hero:tech-aria-label')}>
        {techBadges.map((tech) => <TechChip label={tech} />)}
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-3 pt-1">
        <a href={projectsHref} class="btn btn-primary">
          {t('hero:cta-work')}
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            aria-hidden="true"
          >
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
        <a href={CvLink} target="_blank" class="btn btn-ghost">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          {t('hero:cta-resume')}
        </a>
      </div>

      <!-- Stats strip -->
      <div
        class="flex flex-wrap items-center gap-5 pt-5 border-t divider-accent"
        aria-label={t('hero:stats-aria-label')}
      >
        {
          stats.map((stat, i) => (
            <>
              <div class="flex items-center gap-2.5">
                <div class="icon-box icon-box-sm" aria-hidden="true">
                  {stat.icon === 'rocket' && (
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" />
                      <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" />
                      <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0" />
                      <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" />
                    </svg>
                  )}
                  {stat.icon === 'code' && (
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <polyline points="16 18 22 12 16 6" />
                      <polyline points="8 6 2 12 8 18" />
                    </svg>
                  )}
                  {stat.icon === 'users' && (
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                      <circle cx="9" cy="7" r="4" />
                      <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                      <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                    </svg>
                  )}
                  {stat.icon === 'zap' && (
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
                    </svg>
                  )}
                </div>
                <div>
                  <div class="text-base font-bold leading-tight text-accent text-heading">
                    {stat.value}
                  </div>
                  <div class="text-xs leading-tight text-body-muted">
                    {t(`hero:stat-${stat.key}`)}
                  </div>
                </div>
              </div>
              {i < stats.length - 1 && (
                <span
                  class="hidden sm:block text-xl leading-none brand-separator"
                  aria-hidden="true"
                >
                  |
                </span>
              )}
            </>
          ))
        }
      </div>
    </div>

    <!-- Right: code block + isotipo -->
    <div class="relative hidden lg:flex items-center justify-end gap-5 animate-fade-in delay-300">
      <div
        class="flex-1 min-w-0 rounded-2xl p-5 font-mono text-xs leading-relaxed card-elevated border-accent-strong"
        role="img"
        aria-label={t('hero:code-aria-label')}
      >
        <div class="flex gap-1.5 mb-4" aria-hidden="true">
          <span class="terminal-dot terminal-dot-primary"></span>
          <span class="terminal-dot terminal-dot-secondary"></span>
          <span class="terminal-dot terminal-dot-muted"></span>
        </div>
        <div class="text-body-muted">{t('hero:code-comment')}</div>
        <div class="mt-1">
          <span class="text-secondary-brand">const</span>
          <span class="text-heading"> developer </span>
          <span class="text-accent">=</span>
          <span class="text-heading"> {'{'}</span>
        </div>
        <div class="pl-4">
          <span class="text-body-secondary">name:</span>
          <span class="text-accent"> "Andejecruher"</span><span class="text-heading">,</span>
        </div>
        <div class="pl-4">
          <span class="text-body-secondary">role:</span>
          <span class="text-accent"> "Full Stack Developer"</span><span class="text-heading">,</span
          >
        </div>
        <div class="pl-4">
          <span class="text-body-secondary">focus:</span>
          <span class="text-heading"> [</span>
          <span class="text-accent">"AI Agents"</span><span class="text-heading">, </span>
          <span class="text-accent">"Automation"</span><span class="text-heading">, </span>
          <span class="text-accent">"SaaS"</span>
          <span class="text-heading">],</span>
        </div>
        <div class="pl-4">
          <span class="text-body-secondary">skills:</span>
          <span class="text-heading"> [</span>
          <span class="text-accent">"Laravel"</span><span class="text-heading">, </span>
          <span class="text-accent">"Python"</span><span class="text-heading">, </span>
          <span class="text-accent">"Node.js"</span><span class="text-heading">, </span>
          <span class="text-accent">"React"</span>
          <span class="text-heading">],</span>
        </div>
        <div class="pl-4">
          <span class="text-body-secondary">passion:</span>
          <span class="text-accent"> {JSON.stringify(t('hero:code-passion'))}</span>
        </div>
        <div><span class="text-heading">{'}'};</span></div>
        <div class="mt-3">
          <span class="text-body-muted">function </span>
          <span class="text-accent">buildSolution</span>
          <span class="text-heading">() {'{'}</span>
        </div>
        <div class="pl-4">
          <span class="text-body-secondary">return </span>
          <span class="text-accent">impact</span>
          <span class="text-heading">;</span>
        </div>
        <div><span class="text-heading">{'}'}</span></div>
      </div>

      <!-- Isotipo -->
      <div class="relative flex-shrink-0">
        <img
          src={isotipoDark.src}
          alt="Andejecruher AC isotipo"
          width={isotipoDark.width}
          height={isotipoDark.height}
          data-theme-logo
          data-logo-light-src={isotipoLight.src}
          data-logo-dark-src={isotipoDark.src}
          data-logo-light-width={String(isotipoLight.width)}
          data-logo-dark-width={String(isotipoDark.width)}
          data-logo-light-height={String(isotipoLight.height)}
          data-logo-dark-height={String(isotipoDark.height)}
          class="relative z-10 w-48 h-48 object-contain animate-float"
        />
      </div>
    </div>
  </div>
</section>
