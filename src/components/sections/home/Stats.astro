---
import { stats } from '../../../data/stats';
import { getLang, useTranslations } from '../../../i18n/utils';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
---

<section class="py-16 px-4 section-bg-secondary border-y divider">
  <div class="max-w-6xl mx-auto">
    <dl class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {
        stats.map((stat, i) => (
          <div
            class={`flex flex-col items-center text-center gap-2 animate-fade-in-up delay-${(i + 1) * 100}`}
          >
            <dt class="text-4xl font-bold text-accent text-heading">{stat.value}</dt>
            <dd class="text-sm text-body-secondary">{t(`hero:stat-${stat.key}`)}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
