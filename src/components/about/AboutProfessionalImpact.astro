---
import SectionHeader from '../ui/SectionHeader.astro';
import AboutIcon from './AboutIcon.astro';

interface ImpactItem {
  title: string;
  description: string;
  icon: string;
}

interface Props {
  heading: string;
  subtitle: string;
  items: readonly ImpactItem[];
}

const { heading, subtitle, items } = Astro.props;
---

<section class="flex flex-col gap-6">
  <SectionHeader title={heading} subtitle={subtitle} align="left" />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5">
    {
      items.map((item, index) => (
        <article class="card card-interactive p-5 md:p-6 flex flex-col gap-3 animate-fade-in-up" style={`animation-delay: ${index * 90}ms`}>
          <span class="icon-box icon-box-md" aria-hidden="true">
            <AboutIcon name={item.icon} class="w-[1.05rem] h-[1.05rem]" />
          </span>
          <h3 class="text-base md:text-lg font-semibold leading-tight text-heading">{item.title}</h3>
          <p class="text-sm leading-relaxed text-body-secondary">{item.description}</p>
        </article>
      ))
    }
  </div>
</section>
