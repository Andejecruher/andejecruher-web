---
interface Props {
  name: string;
  role: string;
  title: string;
  subtitle: string;
  specializations: readonly string[];
  logoDarkSrc: string;
  logoLightSrc: string;
  logoDarkWidth: number;
  logoDarkHeight: number;
  logoLightWidth: number;
  logoLightHeight: number;
}

const {
  name,
  role,
  title,
  subtitle,
  specializations,
  logoDarkSrc,
  logoLightSrc,
  logoDarkWidth,
  logoDarkHeight,
  logoLightWidth,
  logoLightHeight,
} = Astro.props;
---

<section class="relative card card-elevated overflow-hidden p-7 md:p-9 xl:p-11 animate-fade-in-up">
  <div class="absolute -top-28 -right-16 h-56 w-56 rounded-full bg-[radial-gradient(circle,_rgba(16,199,223,0.22)_0%,_rgba(16,199,223,0)_72%)]" aria-hidden="true"></div>
  <div class="absolute -bottom-28 left-1/3 h-56 w-72 rounded-full bg-[radial-gradient(circle,_rgba(20,241,201,0.14)_0%,_rgba(20,241,201,0)_72%)]" aria-hidden="true"></div>

  <div class="relative z-10 grid grid-cols-1 lg:grid-cols-[auto_1fr] gap-7 lg:gap-9 items-center">
    <div class="relative w-28 h-28 md:w-32 md:h-32 rounded-2xl flex items-center justify-center panel-accent mx-auto lg:mx-0">
      <div class="absolute inset-0 rounded-2xl opacity-[0.12] glow-radial-subtle" aria-hidden="true"></div>
      <img
        src={logoDarkSrc}
        alt="Andejecruher AC isotipo"
        width={logoDarkWidth}
        height={logoDarkHeight}
        data-theme-logo
        data-logo-light-src={logoLightSrc}
        data-logo-dark-src={logoDarkSrc}
        data-logo-light-width={String(logoLightWidth)}
        data-logo-dark-width={String(logoDarkWidth)}
        data-logo-light-height={String(logoLightHeight)}
        data-logo-dark-height={String(logoDarkHeight)}
        class="w-20 h-20 md:w-24 md:h-24 object-contain relative z-10"
      />
    </div>

    <div class="flex flex-col gap-5 text-center lg:text-left">
      <header class="flex flex-col gap-3">
        <p class="text-xs md:text-sm font-mono tracking-wide text-accent">{name} · {role}</p>
        <h2 class="text-3xl sm:text-4xl xl:text-5xl font-semibold leading-[1.08] tracking-tight text-heading text-balance">
          {title}
        </h2>
        <p class="max-w-3xl text-base md:text-lg leading-relaxed text-body-secondary mx-auto lg:mx-0">
          {subtitle}
        </p>
      </header>

      <ul class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-6 gap-3" role="list">
        {
          specializations.map((item, index) => (
            <li class="chip chip-accent min-h-11 px-3.5 py-2.5 md:px-4 md:py-3 justify-center text-center text-xs md:text-sm font-medium leading-snug animate-fade-in-up" style={`animation-delay: ${120 + index * 85}ms`}>
              {item}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
