---
import { getLang, useTranslations } from '../../i18n/utils';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
---

<div class="blog-primary-controls" role="group" aria-label={t('blog:primary-controls-label')}>
  <div class="blog-search-field">
    <label for="blog-search" class="text-label block">{t('blog:search-label')}</label>
    <div class="blog-search-wrap">
      <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <input
        id="blog-search"
        type="search"
        autocomplete="off"
        placeholder={t('blog:search-placeholder')}
      />
    </div>
  </div>

  <div class="blog-sort-field">
    <label for="blog-sort" class="text-label block">{t('blog:sort-label')}</label>
    <select id="blog-sort" class="blog-select">
      <option value="newest">{t('blog:sort-newest')}</option>
      <option value="oldest">{t('blog:sort-oldest')}</option>
      <option value="shortest">{t('blog:sort-shortest')}</option>
      <option value="longest">{t('blog:sort-longest')}</option>
    </select>
  </div>
</div>
