---
import { getLang, useTranslations } from '../../i18n/utils';

interface Props {
  postCount: number;
}

const { postCount } = Astro.props;
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
---

<section class="relative py-20 px-4 overflow-hidden section-bg-page-header">
  <div
    class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-48 opacity-20 pointer-events-none glow-radial-subtle"
    aria-hidden="true"
  >
  </div>

  <div class="max-w-6xl mx-auto text-center relative z-10">
    <span class="badge badge-accent mb-4">
      <span class="w-1.5 h-1.5 rounded-full bg-current inline-block" aria-hidden="true"></span>
      {t('blog:hero-badge')}
    </span>

    <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-balance mb-4 text-heading">
      {t('blog:hero-title')}
    </h1>

    <p class="text-base md:text-lg leading-relaxed max-w-2xl mx-auto mb-6 text-body-secondary">
      {t('blog:hero-description')}
    </p>

    {
      postCount > 0 && (
        <p class="text-sm font-mono text-body-muted">
          {postCount}{' '}
          {postCount === 1 ? t('blog:hero-post-count-one') : t('blog:hero-post-count-other')}
        </p>
      )
    }
  </div>
</section>
