---
import { localizePath } from '../../i18n/routing';
import { getLang, useTranslations } from '../../i18n/utils';

interface Props {
  image?: string;
  category: string;
  title: string;
  description: string;
  pubDate: Date;
  readingTime?: number;
  tags: string[];
  slug: string;
  index?: number;
}

const {
  image,
  category,
  title,
  description,
  pubDate,
  readingTime,
  tags,
  slug,
  index = 0,
} = Astro.props;

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const dateLocale = lang === 'en' ? 'en-US' : 'es-ES';
const postHref = localizePath(`/blog/${slug}`, lang);

const formattedDate = pubDate.toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const estimatedReadingTime = readingTime ?? 5;
---

<article
  class="group glass-card rounded-2xl flex flex-col overflow-hidden transition-all duration-300 animate-fade-in-up"
  style={`animation-delay: ${index * 80}ms`}
>
  {
    image ? (
      <a
        href={postHref}
        class="block overflow-hidden aspect-video"
        tabindex="-1"
        aria-hidden="true"
      >
        <img
          src={image}
          alt={title}
          width="640"
          height="360"
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      </a>
    ) : (
      <a
        href={postHref}
        class="block overflow-hidden aspect-video bg-gradient-to-br from-brand-primary/10 to-brand-secondary/5 flex items-center justify-center"
        tabindex="-1"
        aria-hidden="true"
      >
        <svg
          width="40"
          height="40"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          class="text-accent opacity-40"
        >
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
        </svg>
      </a>
    )
  }

  <div class="flex flex-col gap-3 p-5 flex-1">
    <span class="badge badge-accent self-start">{category}</span>

    <h2 class="text-base font-semibold leading-snug text-heading">
      <a href={postHref} class="hover:text-brand-primary transition-colors duration-200">
        {title}
      </a>
    </h2>

    <p class="text-sm leading-relaxed flex-1 line-clamp-3 text-body-secondary">
      {description}
    </p>

    <div class="flex items-center justify-between gap-3 pt-1">
      <time datetime={pubDate.toISOString()} class="text-xs font-mono text-body-muted">
        {formattedDate}
      </time>
      <span class="text-xs font-mono flex items-center gap-1 text-body-muted">
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M12 6v6l4 2"></path>
        </svg>
        {t('blog:card-reading-time', { minutes: String(estimatedReadingTime) })}
      </span>
    </div>

    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 pt-1 border-t divider">
          {tags.slice(0, 3).map((tag) => (
            <span class="chip badge-neutral text-xs">#{tag}</span>
          ))}
        </div>
      )
    }

    <a
      href={postHref}
      class="inline-flex items-center gap-1.5 text-xs font-semibold link-accent mt-1"
      aria-label={t('blog:card-read-more-aria', { title })}
    >
      {t('blog:card-read-more')}
      <svg
        width="12"
        height="12"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        aria-hidden="true"
      >
        <path d="M5 12h14M12 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>
</article>
