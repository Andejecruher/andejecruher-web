---
import { getLang, useTranslations } from '../../i18n/utils';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);

const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
  filtered.length > 2 && (
    <nav class="glass-card rounded-xl p-5" aria-label={t('blog:toc-aria-label')}>
      <p class="text-label mb-4">{t('blog:toc-title')}</p>
      <ol class="flex flex-col gap-2" role="list">
        {filtered.map((heading) => (
          <li class={heading.depth === 3 ? 'pl-3' : ''}>
            <a
              href={`#${heading.slug}`}
              class={`text-sm leading-snug link-muted block ${
                heading.depth === 2 ? 'text-body-secondary' : 'text-body-muted'
              }`}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )
}
