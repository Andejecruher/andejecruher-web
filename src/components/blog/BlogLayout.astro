---
/**
 * BlogLayout — consistent max-width wrapper for blog sections.
 */

interface Props {
  title?: string;
  subtitle?: string;
  maxWidth?: 'max-w-3xl' | 'max-w-4xl' | 'max-w-5xl' | 'max-w-6xl' | 'max-w-7xl';
  paddingY?: string;
  class?: string;
}

const {
  title,
  subtitle,
  maxWidth = 'max-w-6xl',
  paddingY = 'section-spacing',
  class: extraClass = '',
} = Astro.props;
---

<section class={`${paddingY} section-bg-primary`}>
  <div class={`${maxWidth} mx-auto ${extraClass}`}>
    {
      (title || subtitle) && (
        <header class="mb-10">
          {title && (
            <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-heading">{title}</h2>
          )}
          {subtitle && (
            <p class="mt-2 text-sm leading-relaxed max-w-2xl text-body-secondary">{subtitle}</p>
          )}
        </header>
      )
    }

    <slot />
  </div>
</section>
