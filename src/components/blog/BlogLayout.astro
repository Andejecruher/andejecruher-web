---
/**
 * BlogLayout — consistent max-width wrapper for blog sections.
 * Provides spacing, optional section title/subtitle, and preserves the
 * dark/cyan glassmorphism design system.
 */

interface Props {
  /** Optional section heading displayed above the slot */
  title?: string;
  /** Optional subheading below the section title */
  subtitle?: string;
  /** Max-width class (default: max-w-6xl) */
  maxWidth?: 'max-w-3xl' | 'max-w-4xl' | 'max-w-5xl' | 'max-w-6xl' | 'max-w-7xl';
  /** Vertical padding (default: py-16) */
  paddingY?: string;
  /** Extra class names forwarded to the inner container */
  class?: string;
}

const {
  title,
  subtitle,
  maxWidth = 'max-w-6xl',
  paddingY = 'py-16',
  class: extraClass = '',
} = Astro.props;
---

<section class={`${paddingY} px-4`} style="background: var(--bg-primary);">
  <div class={`${maxWidth} mx-auto ${extraClass}`}>
    {(title || subtitle) && (
      <header class="mb-10">
        {title && (
          <h2
            class="text-2xl md:text-3xl font-bold tracking-tight"
            style="font-family: var(--font-heading); color: var(--text-primary);"
          >
            {title}
          </h2>
        )}
        {subtitle && (
          <p
            class="mt-2 text-sm leading-relaxed max-w-2xl"
            style="color: var(--text-secondary);"
          >
            {subtitle}
          </p>
        )}
      </header>
    )}

    <slot />
  </div>
</section>
