---
import { getLang, useTranslations } from '../../i18n/utils';

interface Props {
  category: string;
  pubDate: Date;
  updatedDate?: Date;
  readingTime?: number;
  author: string;
}

const { category, pubDate, updatedDate, readingTime, author } = Astro.props;
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const dateLocale = lang === 'en' ? 'en-US' : 'es-ES';

const formattedPubDate = pubDate.toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString(dateLocale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const estimatedReadingTime = readingTime ?? 5;
---

<div class="flex flex-wrap items-center gap-3 text-sm">
  <span class="badge badge-accent">{category}</span>

  <span class="text-body-muted opacity-50">·</span>

  <span class="text-xs font-mono flex items-center gap-1.5 text-body-secondary">
    <svg
      width="12"
      height="12"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
      <circle cx="12" cy="7" r="4"></circle>
    </svg>
    {author}
  </span>

  <span class="text-body-muted opacity-50">·</span>

  <time
    datetime={pubDate.toISOString()}
    class="text-xs font-mono flex items-center gap-1.5 text-body-muted"
  >
    <svg
      width="12"
      height="12"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
      <path d="M16 2v4M8 2v4M3 10h18"></path>
    </svg>
    {formattedPubDate}
  </time>

  {
    updatedDate && (
      <>
        <span class="text-body-muted opacity-50">·</span>
        <time
          datetime={updatedDate.toISOString()}
          class="text-xs font-mono flex items-center gap-1.5 text-body-muted"
          title={t('blog:meta-updated-title')}
        >
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <polyline points="23 4 23 10 17 10" />
            <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10" />
          </svg>
          {t('blog:meta-updated-prefix')} {formattedUpdatedDate}
        </time>
      </>
    )
  }

  <span class="text-body-muted opacity-50">·</span>

  <span class="text-xs font-mono flex items-center gap-1.5 text-body-muted">
    <svg
      width="12"
      height="12"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10"></circle>
      <path d="M12 6v6l4 2"></path>
    </svg>
    {t('blog:meta-reading-time', { minutes: String(estimatedReadingTime) })}
  </span>
</div>
