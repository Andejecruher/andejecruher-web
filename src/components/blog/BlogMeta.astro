---
interface Props {
  category: string;
  pubDate: Date;
  updatedDate?: Date;
  readingTime?: number;
  author: string;
}

const { category, pubDate, updatedDate, readingTime, author } = Astro.props;

const formattedPubDate = pubDate.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('es-ES', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const estimatedReadingTime = readingTime ?? 5;
---

<div class="flex flex-wrap items-center gap-3 text-sm">
  <!-- Category -->
  <span
    class="px-2.5 py-1 rounded-full text-xs font-mono font-medium"
    style="background: rgba(34,211,238,0.08); border: 1px solid rgba(34,211,238,0.2); color: var(--cyan-main);"
  >
    {category}
  </span>

  <!-- Separator -->
  <span style="color: var(--border-primary);">·</span>

  <!-- Author -->
  <span class="text-xs font-mono flex items-center gap-1.5" style="color: var(--text-secondary);">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
      <circle cx="12" cy="7" r="4"/>
    </svg>
    {author}
  </span>

  <!-- Separator -->
  <span style="color: var(--border-primary);">·</span>

  <!-- Pub Date -->
  <time
    datetime={pubDate.toISOString()}
    class="text-xs font-mono flex items-center gap-1.5"
    style="color: var(--text-muted);"
  >
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
      <path d="M16 2v4M8 2v4M3 10h18"/>
    </svg>
    {formattedPubDate}
  </time>

  {updatedDate && (
    <>
      <span style="color: var(--border-primary);">·</span>
      <time
        datetime={updatedDate.toISOString()}
        class="text-xs font-mono flex items-center gap-1.5"
        style="color: var(--text-muted);"
        title="Actualizado"
      >
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <polyline points="23 4 23 10 17 10"/>
          <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
        </svg>
        Act. {formattedUpdatedDate}
      </time>
    </>
  )}

  <!-- Separator -->
  <span style="color: var(--border-primary);">·</span>

  <!-- Reading Time -->
  <span class="text-xs font-mono flex items-center gap-1.5" style="color: var(--text-muted);">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/>
      <path d="M12 6v6l4 2"/>
    </svg>
    {estimatedReadingTime} min de lectura
  </span>
</div>
