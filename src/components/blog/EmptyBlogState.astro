---
import { getLang, useTranslations } from '../../i18n/utils';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
---

<div class="py-16 text-center">
  <div class="icon-box icon-box-lg mx-auto mb-6 w-16 h-16 rounded-2xl" aria-hidden="true">
    <svg
      width="28"
      height="28"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
    >
      <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
      <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
    </svg>
  </div>
  <h2 class="text-xl font-semibold mb-3 text-heading">{t('blog:empty-state-title')}</h2>
  <p class="text-sm leading-relaxed max-w-sm mx-auto text-body-secondary">
    {t('blog:empty-state-body')}
  </p>
</div>
