---
import PageHeader from '../components/ui/PageHeader.astro';
import { getProfile } from '../data/profile';
import { getLang, useTranslations } from '../i18n/utils';
import MainLayout from '../layouts/MainLayout.astro';
import { getPageSeo } from '../seo/pages';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const profile = getProfile(lang);

const contactMethods = [
  {
    label: 'Email',
    value: profile.email,
    href: `mailto:${profile.email}`,
    description: t('contact:method-email-description'),
    icon: 'email',
    external: false,
  },
  {
    label: 'WhatsApp',
    value: '(+52) 322 318 8252',
    href: 'https://wa.me/523223188252',
    description: t('contact:method-whatsapp-description'),
    icon: 'whatsapp',
    external: true,
  },
  {
    label: 'GitHub',
    value: 'github.com/Andejecruher',
    href: 'https://github.com/Andejecruher',
    description: t('contact:method-github-description'),
    icon: 'github',
    external: true,
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/andejecruher',
    href: 'https://www.linkedin.com/in/andejecruher/',
    description: t('contact:method-linkedin-description'),
    icon: 'linkedin',
    external: true,
  },
];
const seo = getPageSeo('contact', lang);
---

<MainLayout {...seo}>
  <PageHeader
    badge={t('contact:header-badge')}
    title={t('contact:header-title')}
    subtitle={t('contact:header-subtitle')}
  />

  <section class="section-spacing section-bg-primary">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div class="flex flex-col gap-6">
          <div>
            <h2 class="text-xl font-semibold mb-2 text-heading">{t('contact:methods-heading')}</h2>
            <p class="text-sm leading-relaxed text-body-secondary">
              {t('contact:methods-subtext')}
            </p>
          </div>

          <ul class="flex flex-col gap-4" role="list">
            {
              contactMethods.map((method) => (
                <li>
                  <a
                    href={method.href}
                    class="card card-interactive flex items-start gap-4 p-4 group"
                    target={method.external ? '_blank' : undefined}
                    rel={method.external ? 'noopener noreferrer' : undefined}
                  >
                    <div class="icon-box icon-box-lg mt-0.5" aria-hidden="true">
                      {method.icon === 'email' && (
                        <svg
                          width="18"
                          height="18"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <rect width="20" height="16" x="2" y="4" rx="2" />
                          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                        </svg>
                      )}
                      {method.icon === 'whatsapp' && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z" />
                        </svg>
                      )}
                      {method.icon === 'github' && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                        </svg>
                      )}
                      {method.icon === 'linkedin' && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                        </svg>
                      )}
                    </div>

                    <div class="flex flex-col gap-0.5 min-w-0">
                      <span class="text-label">{method.label}</span>
                      <span class="text-sm font-mono truncate text-accent">{method.value}</span>
                      <span class="text-xs text-body-muted">{method.description}</span>
                    </div>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <div class="mb-6">
            <h2 class="text-xl font-semibold mb-2 text-heading">{t('contact:form-heading')}</h2>
            <p class="text-sm leading-relaxed text-body-secondary">{t('contact:form-subtext')}</p>
          </div>

          <form
            id="contact-form"
            class="flex flex-col gap-5"
            novalidate
            data-status-sending={t('contact:form-status-sending')}
            data-status-sending-detail={t('contact:form-status-sending-detail')}
            data-status-success={t('contact:form-status-success')}
            data-status-success-detail={t('contact:form-status-success-detail')}
            data-status-success-time={t('contact:form-status-success-time')}
            data-status-error={t('contact:form-status-error')}
            data-status-error-detail={t('contact:form-status-error-detail')}
            data-status-validation={t('contact:form-status-validation')}
            data-status-validation-detail={t('contact:form-status-validation-detail')}
            data-status-missing-config={t('contact:form-status-missing-config')}
            data-submit-idle={t('contact:form-submit')}
            data-submit-loading={t('contact:form-submit-sending')}
            data-error-name-required={t('contact:form-error-name-required')}
            data-error-email-required={t('contact:form-error-email-required')}
            data-error-email-invalid={t('contact:form-error-email-invalid')}
            data-error-subject-required={t('contact:form-error-subject-required')}
            data-error-message-required={t('contact:form-error-message-required')}
            aria-describedby="contact-status"
          >
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="flex flex-col gap-1.5">
                <label for="name" class="form-label">
                  {t('contact:form-name-label')}
                  <span class="text-accent" aria-label={t('contact:form-required-aria')}>*</span>
                </label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  required
                  placeholder={t('contact:form-name-placeholder')}
                  autocomplete="name"
                  aria-describedby="name-error"
                  class="form-input"
                />
                <p
                  id="name-error"
                  data-error-for="name"
                  class="text-xs text-rose-300"
                  aria-live="polite"
                  hidden
                >
                </p>
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="email" class="form-label">
                  {t('contact:form-email-label')}
                  <span class="text-accent" aria-label={t('contact:form-required-aria')}>*</span>
                </label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  placeholder={t('contact:form-email-placeholder')}
                  autocomplete="email"
                  aria-describedby="email-error"
                  class="form-input"
                />
                <p
                  id="email-error"
                  data-error-for="email"
                  class="text-xs text-rose-300"
                  aria-live="polite"
                  hidden
                >
                </p>
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="subject" class="form-label">
                {t('contact:form-subject-label')}
                <span class="text-accent" aria-label={t('contact:form-required-aria')}>*</span>
              </label>
              <input
                id="subject"
                name="subject"
                type="text"
                required
                placeholder={t('contact:form-subject-placeholder')}
                autocomplete="off"
                aria-describedby="subject-error"
                class="form-input"
              />
              <p
                id="subject-error"
                data-error-for="subject"
                class="text-xs text-rose-300"
                aria-live="polite"
                hidden
              >
              </p>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="message" class="form-label">
                {t('contact:form-message-label')}
                <span class="text-accent" aria-label={t('contact:form-required-aria')}>*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder={t('contact:form-message-placeholder')}
                aria-describedby="message-error"
                class="form-input resize-none"></textarea>
              <p
                id="message-error"
                data-error-for="message"
                class="text-xs text-rose-300"
                aria-live="polite"
                hidden
              >
              </p>
            </div>

            <button id="contact-submit" type="submit" class="btn btn-primary w-full min-h-11">
              <svg
                id="contact-submit-spinner"
                class="contact-spinner contact-svg-hidden"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <circle
                  cx="12"
                  cy="12"
                  r="9"
                  stroke="currentColor"
                  stroke-opacity="0.3"
                  stroke-width="3"></circle>
                <path
                  d="M21 12a9 9 0 0 0-9-9"
                  stroke="currentColor"
                  stroke-width="3"
                  stroke-linecap="round"></path>
              </svg>
              <span id="contact-submit-label">{t('contact:form-submit')}</span>
            </button>

            <div
              id="contact-status"
              class="contact-status"
              role="status"
              aria-live="polite"
              aria-atomic="true"
              hidden
            >
              <div class="contact-status-icon" aria-hidden="true">
                <svg
                  data-status-icon="loading"
                  class="contact-spinner contact-svg-hidden"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                >
                  <circle
                    cx="12"
                    cy="12"
                    r="9"
                    stroke="currentColor"
                    stroke-opacity="0.25"
                    stroke-width="3"></circle>
                  <path
                    d="M21 12a9 9 0 0 0-9-9"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"></path>
                </svg>
                <svg
                  data-status-icon="success"
                  class="contact-svg-hidden"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                >
                  <path
                    d="m5 12 4 4L19 6"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
                <svg
                  data-status-icon="error"
                  class="contact-svg-hidden"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                >
                  <path
                    d="M12 8v5m0 3.5v.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"></path>
                </svg>
              </div>
              <div>
                <p id="contact-status-title" class="contact-status-title"></p>
                <p id="contact-status-detail" class="contact-status-detail"></p>
              </div>
            </div>

            <p class="text-xs text-center text-body-muted">{t('contact:form-disclaimer')}</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <style>
    .contact-status {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 0.875rem 1rem;
      border: 1px solid var(--color-border);
      border-radius: 0.85rem;
      background: var(--color-surface-glass);
      color: var(--color-text-secondary);
      animation: status-enter 180ms ease-out;
    }

    .contact-status[hidden] {
      display: none;
    }

    .contact-status[data-state='loading'] {
      border-color: var(--color-info-border);
      background: var(--color-info-soft);
      color: var(--color-info);
    }

    .contact-status[data-state='success'] {
      border-color: var(--color-success-border);
      background: var(--color-success-soft);
      color: var(--color-success);
    }

    .contact-status[data-state='error'] {
      border-color: color-mix(in srgb, #fb7185 35%, transparent);
      background: color-mix(in srgb, #fb7185 9%, transparent);
      color: #fb7185;
    }

    .contact-status-icon {
      display: grid;
      flex: 0 0 auto;
      width: 2rem;
      height: 2rem;
      place-items: center;
      border-radius: 999px;
      background: color-mix(in srgb, currentColor 12%, transparent);
    }

    .contact-status-title {
      color: currentColor;
      font-size: 0.875rem;
      font-weight: 700;
      line-height: 1.35;
    }

    .contact-status-detail {
      margin-top: 0.15rem;
      color: var(--color-text-secondary);
      font-size: 0.75rem;
      line-height: 1.5;
    }

    .contact-spinner {
      animation: contact-spin 800ms linear infinite;
    }

    .contact-svg-hidden {
      display: none;
    }

    @keyframes contact-spin {
      to {
        transform: rotate(360deg);
      }
    }

    @keyframes status-enter {
      from {
        opacity: 0;
        transform: translateY(-4px);
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .contact-spinner,
      .contact-status {
        animation: none;
      }
    }
  </style>

  <script>
    import emailjs from '@emailjs/browser';

    const formElement = document.getElementById('contact-form');
    const submitElement = document.getElementById('contact-submit');
    const statusElement = document.getElementById('contact-status');
    const submitLabelElement = document.getElementById('contact-submit-label');
    const submitSpinnerElement = document.getElementById('contact-submit-spinner');
    const statusTitleElement = document.getElementById('contact-status-title');
    const statusDetailElement = document.getElementById('contact-status-detail');

    if (
      formElement instanceof HTMLFormElement &&
      submitElement instanceof HTMLButtonElement &&
      statusElement instanceof HTMLElement &&
      submitLabelElement instanceof HTMLElement &&
      submitSpinnerElement instanceof SVGElement &&
      statusTitleElement instanceof HTMLElement &&
      statusDetailElement instanceof HTMLElement
    ) {
      const config = {
        serviceId: (import.meta.env.PUBLIC_EMAILJS_SERVICE_ID ?? '').trim(),
        templateId: (import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID ?? '').trim(),
        templateConfirmationId: (
          import.meta.env.PUBLIC_EMAILJS_TEMPLATE_CONFIRMATION_ID ?? ''
        ).trim(),
        publicKey: (import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY ?? '').trim(),
      };

      const messages = {
        submitIdle: formElement.dataset.submitIdle?.trim() ?? 'Send message',
        submitLoading: formElement.dataset.submitLoading?.trim() ?? 'Sending message…',
        sending: formElement.dataset.statusSending?.trim() ?? 'Sending message…',
        sendingDetail:
          formElement.dataset.statusSendingDetail?.trim() ?? 'Please keep this page open.',
        success: formElement.dataset.statusSuccess?.trim() ?? 'Message sent successfully.',
        successDetail:
          formElement.dataset.statusSuccessDetail?.trim() ?? 'I will reply within 24 hours.',
        successTime: formElement.dataset.statusSuccessTime?.trim() ?? 'Sent at',
        error:
          formElement.dataset.statusError?.trim() ?? 'Message could not be sent. Please try again.',
        errorDetail:
          formElement.dataset.statusErrorDetail?.trim() ??
          'Your message is still here. Check your connection and try again.',
        validation:
          formElement.dataset.statusValidation?.trim() ?? 'Review the highlighted fields.',
        validationDetail:
          formElement.dataset.statusValidationDetail?.trim() ??
          'A few details are missing before the message can be sent.',
        missingConfig:
          formElement.dataset.statusMissingConfig?.trim() ??
          'Email service is not configured. Please try again later.',
        nameRequired: formElement.dataset.errorNameRequired?.trim() ?? 'Please enter your name.',
        emailRequired: formElement.dataset.errorEmailRequired?.trim() ?? 'Please enter your email.',
        emailInvalid:
          formElement.dataset.errorEmailInvalid?.trim() ?? 'Please enter a valid email address.',
        subjectRequired:
          formElement.dataset.errorSubjectRequired?.trim() ?? 'Please enter a subject.',
        messageRequired:
          formElement.dataset.errorMessageRequired?.trim() ?? 'Please enter your message.',
      };

      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/u;
      const successResetDelayMs = 8_000;
      type FormState = 'idle' | 'loading' | 'success' | 'error';
      let state: FormState = 'idle';
      let successResetTimeout: number | undefined;

      const getInputByName = (name: string) => {
        const field = formElement.elements.namedItem(name);
        return field instanceof HTMLInputElement ? field : undefined;
      };

      const getTextAreaByName = (name: string) => {
        const field = formElement.elements.namedItem(name);
        return field instanceof HTMLTextAreaElement ? field : undefined;
      };

      const fields = {
        name: getInputByName('name'),
        email: getInputByName('email'),
        subject: getInputByName('subject'),
        message: getTextAreaByName('message'),
      };

      type FieldName = keyof typeof fields;

      const clearSuccessReset = () => {
        if (successResetTimeout !== undefined) {
          window.clearTimeout(successResetTimeout);
          successResetTimeout = undefined;
        }
      };

      const setState = (nextState: FormState, detail = '', title?: string) => {
        clearSuccessReset();
        state = nextState;
        submitElement.disabled = nextState === 'loading';
        submitLabelElement.textContent =
          nextState === 'loading' ? messages.submitLoading : messages.submitIdle;
        submitSpinnerElement.classList.toggle('contact-svg-hidden', nextState !== 'loading');
        formElement.setAttribute('aria-busy', nextState === 'loading' ? 'true' : 'false');

        if (nextState === 'idle') {
          statusElement.hidden = true;
          statusElement.removeAttribute('data-state');
          statusTitleElement.textContent = '';
          statusDetailElement.textContent = '';
          return;
        }

        const statusTitles = {
          loading: messages.sending,
          success: messages.success,
          error: messages.error,
        } satisfies Record<Exclude<FormState, 'idle'>, string>;

        statusElement.hidden = false;
        statusElement.dataset.state = nextState;
        statusTitleElement.textContent = title ?? statusTitles[nextState];
        statusDetailElement.textContent = detail;

        statusElement.querySelectorAll<SVGElement>('[data-status-icon]').forEach((icon) => {
          icon.classList.toggle('contact-svg-hidden', icon.dataset.statusIcon !== nextState);
        });
      };

      const scheduleSuccessReset = () => {
        successResetTimeout = window.setTimeout(() => {
          setState('idle');
        }, successResetDelayMs);
      };

      const getFieldErrorElement = (fieldName: FieldName) => {
        const errorCandidate = formElement.querySelector(`[data-error-for="${fieldName}"]`);
        return errorCandidate instanceof HTMLElement ? errorCandidate : undefined;
      };

      const setFieldError = (fieldName: FieldName, message: string | undefined) => {
        const field = fields[fieldName];
        if (field !== undefined) {
          field.setAttribute('aria-invalid', message !== undefined ? 'true' : 'false');
        }

        const errorElement = getFieldErrorElement(fieldName);
        if (errorElement !== undefined) {
          errorElement.textContent = message ?? '';
          errorElement.hidden = message === undefined;
        }
      };

      const clearFieldErrors = () => {
        setFieldError('name', undefined);
        setFieldError('email', undefined);
        setFieldError('subject', undefined);
        setFieldError('message', undefined);
      };

      const validateForm = () => {
        clearFieldErrors();

        const nameValue = fields.name?.value.trim() ?? '';
        const emailValue = fields.email?.value.trim() ?? '';
        const subjectValue = fields.subject?.value.trim() ?? '';
        const messageValue = fields.message?.value.trim() ?? '';

        let firstInvalidField: HTMLInputElement | HTMLTextAreaElement | undefined;

        if (nameValue.length === 0) {
          setFieldError('name', messages.nameRequired);
          firstInvalidField = fields.name;
        }

        if (emailValue.length === 0) {
          setFieldError('email', messages.emailRequired);
          firstInvalidField = firstInvalidField ?? fields.email;
        } else if (!emailRegex.test(emailValue)) {
          setFieldError('email', messages.emailInvalid);
          firstInvalidField = firstInvalidField ?? fields.email;
        }

        if (fields.subject !== undefined && subjectValue.length === 0) {
          setFieldError('subject', messages.subjectRequired);
          firstInvalidField = firstInvalidField ?? fields.subject;
        }

        if (messageValue.length === 0) {
          setFieldError('message', messages.messageRequired);
          firstInvalidField = firstInvalidField ?? fields.message;
        }

        if (firstInvalidField !== undefined) {
          firstInvalidField.focus();
          setState('error', messages.validationDetail, messages.validation);
          return false;
        }

        return true;
      };

      formElement.addEventListener('input', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLInputElement) && !(target instanceof HTMLTextAreaElement)) {
          return;
        }

        if (
          target.name === 'name' ||
          target.name === 'email' ||
          target.name === 'subject' ||
          target.name === 'message'
        ) {
          setFieldError(target.name, undefined);
        }

        if (state === 'success' || state === 'error') {
          setState('idle');
        }
      });

      formElement.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (state === 'loading') {
          return;
        }

        if (!validateForm()) {
          return;
        }

        if (
          config.serviceId.length === 0 ||
          config.templateId.length === 0 ||
          config.publicKey.length === 0
        ) {
          setState('error', messages.missingConfig);
          return;
        }

        try {
          setState('loading', messages.sendingDetail);
          await emailjs.sendForm(config.serviceId, config.templateId, formElement, {
            publicKey: config.publicKey,
          });
          formElement.reset();
          clearFieldErrors();
          const sentTime = new Intl.DateTimeFormat(document.documentElement.lang, {
            hour: 'numeric',
            minute: '2-digit',
          }).format(new Date());
          setState('success', `${messages.successDetail} · ${messages.successTime} ${sentTime}`);
          scheduleSuccessReset();
        } catch {
          setState('error', messages.errorDetail);
        }
      });
    }
  </script>
</MainLayout>
