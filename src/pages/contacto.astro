---
import MainLayout from '../layouts/MainLayout.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import { socialLinks } from '../data/socialLinks';

const contactMethods = [
  {
    label: 'Email',
    value: 'andejecruher@gmail.com',
    href: 'mailto:andejecruher@gmail.com',
    description: 'Para consultas de proyectos o colaboraciones.',
    icon: 'email',
    external: false,
  },
  {
    label: 'WhatsApp',
    value: '(+52) 322 318 8252',
    href: 'https://wa.me/523223188252',
    description: 'Para conversaciones rápidas y consultas directas.',
    icon: 'whatsapp',
    external: true,
  },
  {
    label: 'GitHub',
    value: 'github.com/Andejecruher',
    href: 'https://github.com/Andejecruher',
    description: 'Revisa mi código y proyectos open source.',
    icon: 'github',
    external: true,
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/andejecruher',
    href: 'https://www.linkedin.com/in/andejecruher/',
    description: 'Conecta conmigo profesionalmente.',
    icon: 'linkedin',
    external: true,
  },
];
---

<MainLayout
  title="Contacto"
  description="Contacta a Andejecruher — Full Stack Developer disponible para proyectos, colaboraciones y consultas técnicas."
>
  <PageHeader
    badge="Contacto"
    title="Hablemos de tu próximo proyecto"
    subtitle="Estoy disponible para proyectos freelance, colaboraciones y consultas técnicas. No dudes en escribir."
  />

  <section class="py-16 px-4" style="background: #020607;">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- Left: contact methods -->
        <div class="flex flex-col gap-6">
          <div>
            <h2
              class="text-xl font-semibold mb-2"
              style="font-family: var(--font-heading); color: #f2f7f8;"
            >
              Métodos de contacto
            </h2>
            <p class="text-sm leading-relaxed" style="color: #a7b0b8;">
              Puedes contactarme por cualquiera de estos canales. Respondo en menos de 24 horas.
            </p>
          </div>

          <ul class="flex flex-col gap-4" role="list">
            {contactMethods.map((method) => (
              <li>
                <a
                  href={method.href}
                  class="flex items-start gap-4 p-4 rounded-xl transition-all duration-200 group"
                  style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08);"
                  onmouseover="this.style.borderColor='rgba(0,229,229,0.25)'; this.style.background='rgba(0,229,229,0.04)';"
                  onmouseout="this.style.borderColor='rgba(255,255,255,0.08)'; this.style.background='rgba(255,255,255,0.03)';"
                  target={method.external ? '_blank' : undefined}
                  rel={method.external ? 'noopener noreferrer' : undefined}
                >
                  <div
                    class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5"
                    style="background: rgba(0,229,229,0.1); border: 1px solid rgba(0,229,229,0.2);"
                    aria-hidden="true"
                  >
                    {method.icon === 'email' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#00e5e5" stroke-width="2">
                        <rect width="20" height="16" x="2" y="4" rx="2"/>
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                      </svg>
                    )}
                    {method.icon === 'whatsapp' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="#00e5e5">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
                      </svg>
                    )}
                    {method.icon === 'github' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="#00e5e5">
                        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                      </svg>
                    )}
                    {method.icon === 'linkedin' && (
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="#00e5e5">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                      </svg>
                    )}
                  </div>

                  <div class="flex flex-col gap-0.5 min-w-0">
                    <span class="text-xs font-semibold uppercase tracking-widest" style="color: #6f7b85; font-family: var(--font-heading);">
                      {method.label}
                    </span>
                    <span class="text-sm font-mono truncate" style="color: #00e5e5;">{method.value}</span>
                    <span class="text-xs" style="color: #6f7b85;">{method.description}</span>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Right: contact form -->
        <div>
          <div class="mb-6">
            <h2
              class="text-xl font-semibold mb-2"
              style="font-family: var(--font-heading); color: #f2f7f8;"
            >
              Envíame un mensaje
            </h2>
            <p class="text-sm leading-relaxed" style="color: #a7b0b8;">
              Describe tu proyecto o consulta y te respondo en menos de 24 horas.
            </p>
          </div>

          <form
            id="contact-form"
            class="flex flex-col gap-5"
            action="https://formspree.io/f/placeholder"
            method="POST"
            novalidate
          >
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="flex flex-col gap-1.5">
                <label for="name" class="text-xs font-semibold uppercase tracking-widest" style="color: #6f7b85; font-family: var(--font-heading);">
                  Nombre <span style="color: #00e5e5;" aria-label="requerido">*</span>
                </label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  required
                  placeholder="Tu nombre"
                  class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all duration-200 font-mono"
                  style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); color: #f2f7f8;"
                  onfocus="this.style.borderColor='rgba(0,229,229,0.4)'"
                  onblur="this.style.borderColor='rgba(255,255,255,0.1)'"
                />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="email" class="text-xs font-semibold uppercase tracking-widest" style="color: #6f7b85; font-family: var(--font-heading);">
                  Email <span style="color: #00e5e5;" aria-label="requerido">*</span>
                </label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  placeholder="tu@email.com"
                  class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all duration-200 font-mono"
                  style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); color: #f2f7f8;"
                  onfocus="this.style.borderColor='rgba(0,229,229,0.4)'"
                  onblur="this.style.borderColor='rgba(255,255,255,0.1)'"
                />
              </div>
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="subject" class="text-xs font-semibold uppercase tracking-widest" style="color: #6f7b85; font-family: var(--font-heading);">
                Asunto
              </label>
              <input
                id="subject"
                name="subject"
                type="text"
                placeholder="¿De qué trata tu proyecto?"
                class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all duration-200 font-mono"
                style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); color: #f2f7f8;"
                onfocus="this.style.borderColor='rgba(0,229,229,0.4)'"
                onblur="this.style.borderColor='rgba(255,255,255,0.1)'"
              />
            </div>

            <div class="flex flex-col gap-1.5">
              <label for="message" class="text-xs font-semibold uppercase tracking-widest" style="color: #6f7b85; font-family: var(--font-heading);">
                Mensaje <span style="color: #00e5e5;" aria-label="requerido">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                placeholder="Cuéntame sobre tu proyecto, idea o consulta..."
                class="w-full px-4 py-3 rounded-xl text-sm outline-none transition-all duration-200 font-mono resize-none"
                style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); color: #f2f7f8;"
                onfocus="this.style.borderColor='rgba(0,229,229,0.4)'"
                onblur="this.style.borderColor='rgba(255,255,255,0.1)'"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full py-3 rounded-xl text-sm font-semibold transition-all duration-200"
              style="background: #00e5e5; color: #020607;"
              onmouseover="this.style.background='#00bfc6'; this.style.boxShadow='0 0 24px rgba(0,229,229,0.3)';"
              onmouseout="this.style.background='#00e5e5'; this.style.boxShadow='none';"
            >
              Enviar mensaje
            </button>

            <p class="text-xs text-center" style="color: #6f7b85;">
              El formulario se conectará próximamente con Formspree o un endpoint propio.
            </p>
          </form>
        </div>

      </div>
    </div>
  </section>
</MainLayout>
