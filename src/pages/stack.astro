---
import PageHeader from '../components/ui/PageHeader.astro';
import { levelColors, stackCategories } from '../data/stack';
import { getLang, useTranslations } from '../i18n/utils';
import MainLayout from '../layouts/MainLayout.astro';
import { getPageSeo } from '../seo/pages';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const seo = getPageSeo('stack', lang);
---

<MainLayout {...seo}>
  <PageHeader
    badge={t('stack:header-badge')}
    title={t('stack:header-title')}
    subtitle={t('stack:header-subtitle')}
  />

  <section class="section-spacing section-bg-primary">
    <div class="max-w-6xl mx-auto">
      <div
        class="flex flex-wrap gap-3 mb-12 justify-center"
        role="group"
        aria-label={t('stack:legend-aria-label')}
      >
        {
          Object.keys(levelColors).map((level) => (
            <span
              class={`badge badge-neutral border ${levelColors[level as keyof typeof levelColors]}`}
            >
              {t(`stack:level-${level}`)}
            </span>
          ))
        }
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {
          stackCategories.map((cat, i) => (
            <div
              class="card p-6 flex flex-col gap-5 animate-fade-in-up"
              style={`animation-delay: ${i * 100}ms`}
            >
              <div>
                <h2 class="text-lg font-semibold mb-1 text-heading">
                  {t(`stack:category-${cat.key}-name`)}
                </h2>
                <p class="text-xs text-body-muted">{t(`stack:category-${cat.key}-desc`)}</p>
              </div>

              <div class="flex flex-col gap-3">
                {cat.techs.map((tech) => (
                  <div class="flex items-center justify-between gap-4">
                    <span class="text-sm font-mono text-body-secondary">{tech.name}</span>
                    <span class={`chip flex-shrink-0 border ${levelColors[tech.level]}`}>
                      {t(`stack:level-${tech.level}`)}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          ))
        }
      </div>

      <div class="mt-12 panel-accent p-5 text-center">
        <p class="text-sm leading-relaxed text-body-secondary">
          {t('stack:footer-note-prefix')}{' '}
          <span class="text-accent">{t('stack:footer-note-highlight-1')}</span>,{' '}
          <span class="text-accent">{t('stack:footer-note-highlight-2')}</span>{' '}
          {t('stack:footer-note-connector')}{' '}
          <span class="text-accent">{t('stack:footer-note-highlight-3')}</span>
          {t('stack:footer-note-suffix')}
        </p>
      </div>
    </div>
  </section>
</MainLayout>
