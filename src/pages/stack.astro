---
import CapabilityCard from '@/components/stack/CapabilityCard.astro';
import DevOpsRoadmap from '@/components/stack/DevOpsRoadmap.astro';
import StackHero from '@/components/stack/StackHero.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import { capabilityMap, devOpsRoadmap, stackSpecializations } from '../data/stack';
import { getLang, useTranslations } from '../i18n/utils';
import MainLayout from '../layouts/MainLayout.astro';
import { getPageSeo } from '../seo/pages';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const seo = getPageSeo('stack', lang);

const heroSpecializations = stackSpecializations.map((specialization) =>
  t(`stack:specialization-${specialization.key}`),
);

const capabilities = capabilityMap.map((capability) => ({
  title: t(`stack:capability-${capability.key}-title`),
  description: t(`stack:capability-${capability.key}-description`),
  technologies: capability.technologies,
}));

const roadmapMilestones = devOpsRoadmap.map((milestone) => ({
  title: t(`stack:roadmap-${milestone.key}-title`),
  description: t(`stack:roadmap-${milestone.key}-description`),
  status: milestone.status,
  statusLabel: t(`stack:status-${milestone.status}`),
}));
---

<MainLayout {...seo}>
  <PageHeader
    badge={t('stack:header-badge')}
    title={t('stack:header-title')}
    subtitle={t('stack:header-subtitle')}
  />

  <section class="section-spacing section-bg-primary">
    <div class="max-w-6xl 2xl:max-w-[88rem] mx-auto">
      <StackHero
        eyebrow={t('stack:hero-eyebrow')}
        title={t('stack:hero-title')}
        subtitle={t('stack:hero-subtitle')}
        specializations={heroSpecializations}
      />

      <section aria-labelledby="capability-map-title" class="mb-12 md:mb-16">
        <header class="mb-9 md:mb-11 max-w-3xl">
          <h2 id="capability-map-title" class="section-heading text-heading mb-3">
            {t('stack:capabilities-title')}
          </h2>
          <p class="max-w-2xl text-sm md:text-base leading-relaxed md:leading-8 text-body-secondary">
            {t('stack:capabilities-subtitle')}
          </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 2xl:grid-cols-3 gap-5 md:gap-6 xl:gap-7">
          {
            capabilities.map((capability, index) => (
              <CapabilityCard
                title={capability.title}
                description={capability.description}
                technologies={capability.technologies}
                delayMs={index * 90}
              />
            ))
          }
        </div>
      </section>

      <DevOpsRoadmap
        title={t('stack:devops-title')}
        subtitle={t('stack:devops-subtitle')}
        milestones={roadmapMilestones}
      />
    </div>
  </section>
</MainLayout>
