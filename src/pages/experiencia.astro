---
import PageHeader from '../components/ui/PageHeader.astro';
import { getExperiences } from '../data/experience';
import { getLang, useTranslations } from '../i18n/utils';
import MainLayout from '../layouts/MainLayout.astro';
import { getPageSeo } from '../seo/pages';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const seo = getPageSeo('experience', lang);
const experiences = getExperiences(lang);
---

<MainLayout {...seo}>
  <PageHeader
    badge={t('experience:header-badge')}
    title={t('experience:header-title')}
    subtitle={t('experience:header-subtitle')}
  />

  <section class="section-spacing section-bg-primary">
    <div class="max-w-4xl mx-auto">
      <div class="card p-4 mb-12 flex gap-3" role="note">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          class="flex-shrink-0 mt-0.5 text-body-muted"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M12 16v-4M12 8h.01"></path>
        </svg>
        <p class="text-sm leading-relaxed text-body-muted">
          {t('experience:confidentiality-note')}
        </p>
      </div>

      <div class="relative">
        <div
          class="absolute left-4 top-0 bottom-0 w-px hidden sm:block timeline-line-accent"
          aria-hidden="true"
        >
        </div>

        <ol class="flex flex-col gap-12" role="list">
          {
            experiences.map((exp, i) => (
              <li
                class="relative sm:pl-14 animate-fade-in-up"
                style={`animation-delay: ${i * 150}ms`}
              >
                <div
                  class="absolute left-0 top-1 w-8 h-8 rounded-full hidden sm:flex items-center justify-center flex-shrink-0 section-bg-footer border-2 border-accent-strong z-[1]"
                  aria-hidden="true"
                >
                  <span class="brand-dot w-2 h-2" />
                </div>

                <article class="card p-6 md:p-8 flex flex-col gap-5">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
                    <div>
                      <h2 class="text-xl font-semibold text-heading">{exp.role}</h2>
                      <p class="text-sm mt-1 font-medium text-accent">{exp.company}</p>
                    </div>
                    <div class="flex flex-col items-start sm:items-end gap-1 flex-shrink-0">
                      <span class="chip chip-accent">{exp.period}</span>
                      <span class="text-xs text-body-muted">{exp.modality}</span>
                    </div>
                  </div>

                  <p class="text-sm leading-relaxed text-body-secondary">{exp.description}</p>

                  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                      <h3 class="text-label mb-3">{t('experience:responsibilities')}</h3>
                      <ul class="flex flex-col gap-2" role="list">
                        {exp.responsibilities.map((r) => (
                          <li class="flex gap-2 text-sm leading-relaxed text-body-secondary">
                            <span
                              class="text-accent mt-1.5 flex-shrink-0 text-xs"
                              aria-hidden="true"
                            >
                              ▸
                            </span>
                            {r}
                          </li>
                        ))}
                      </ul>
                    </div>
                    <div>
                      <h3 class="text-label mb-3">{t('experience:achievements')}</h3>
                      <ul class="flex flex-col gap-2" role="list">
                        {exp.achievements.map((a) => (
                          <li class="flex gap-2 text-sm leading-relaxed text-body-secondary">
                            <span
                              class="text-accent mt-1.5 flex-shrink-0 text-xs"
                              aria-hidden="true"
                            >
                              ✓
                            </span>
                            {a}
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>

                  <div>
                    <h3 class="text-label mb-3">{t('experience:technologies')}</h3>
                    <div class="flex flex-wrap gap-2">
                      {exp.technologies.map((tech) => (
                        <span class="chip-tech">{tech}</span>
                      ))}
                    </div>
                  </div>

                  {exp.confidential && (
                    <div class="card-inner flex gap-2 p-3" role="note">
                      <svg
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        class="flex-shrink-0 mt-0.5 text-body-muted"
                        aria-hidden="true"
                      >
                        <rect width="18" height="11" x="3" y="11" rx="2" ry="2" />
                        <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                      </svg>
                      <p class="text-xs text-body-muted">
                        {t('experience:confidential-item-note')}
                      </p>
                    </div>
                  )}
                </article>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>
</MainLayout>
