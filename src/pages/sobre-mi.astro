---
import isotipoDark from '../assets/isotipo-dark.png';
import isotipoLight from '../assets/isotipo.png';
import AboutCareerJourney from '../components/about/AboutCareerJourney.astro';
import AboutExecutiveSummary from '../components/about/AboutExecutiveSummary.astro';
import AboutFocusAreas from '../components/about/AboutFocusAreas.astro';
import AboutHero from '../components/about/AboutHero.astro';
import AboutProfessionalGoal from '../components/about/AboutProfessionalGoal.astro';
import AboutProfessionalImpact from '../components/about/AboutProfessionalImpact.astro';
import AboutQuickInfoPanel from '../components/about/AboutQuickInfoPanel.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import { focusAreas } from '../data/focusAreas';
import { getProfile } from '../data/profile';
import { socialLinks } from '../data/socialLinks';
import { getLang, useTranslations } from '../i18n/utils';
import MainLayout from '../layouts/MainLayout.astro';
import { getPageSeo } from '../seo/pages';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const profile = getProfile(lang);
const seo = getPageSeo('about', lang);

const heroSpecializations = [
  t('about:hero-chip-backend'),
  t('about:hero-chip-frontend'),
  t('about:hero-chip-saas'),
  t('about:hero-chip-ai'),
  t('about:hero-chip-automation'),
  t('about:hero-chip-integrations'),
];

const executiveSummaryParagraphs = [
  t('about:executive-summary-p1'),
  t('about:executive-summary-p2'),
  t('about:executive-summary-p3'),
];

const quickInfoItems = [
  { label: t('about:quick-info-location'), value: profile.location, icon: 'map-pin' },
  { label: t('about:quick-info-modality'), value: t('about:quick-info-modality-value'), icon: 'monitor' },
  {
    label: t('about:quick-info-role'),
    value: `${profile.role} · ${t('about:quick-info-role-value')}`,
    icon: 'briefcase',
  },
  {
    label: t('about:quick-info-specialization'),
    value: t('about:quick-info-specialization-value'),
    icon: 'sparkles',
  },
  {
    label: t('about:quick-info-availability'),
    value: profile.availableForProjects
      ? t('about:available-for-projects')
      : t('about:quick-info-availability-limited'),
    icon: 'calendar-check',
  },
];

const mappedFocusAreas = focusAreas.map((area) => ({
  icon: area.icon,
  title: t(`about:focus-${area.key}-title`),
  description: t(`about:focus-${area.key}-desc`),
}));

const impactItems = [
  {
    icon: 'layers',
    title: t('about:impact-platform-title'),
    description: t('about:impact-platform-desc'),
  },
  {
    icon: 'link-2',
    title: t('about:impact-integrations-title'),
    description: t('about:impact-integrations-desc'),
  },
  {
    icon: 'workflow',
    title: t('about:impact-execution-title'),
    description: t('about:impact-execution-desc'),
  },
  {
    icon: 'trending-up',
    title: t('about:impact-growth-title'),
    description: t('about:impact-growth-desc'),
  },
];

const journeySteps = [
  { icon: 'code-2', label: t('about:journey-step-frontend') },
  { icon: 'server', label: t('about:journey-step-backend') },
  { icon: 'building-2', label: t('about:journey-step-saas') },
  { icon: 'workflow', label: t('about:journey-step-automation') },
  { icon: 'bot', label: t('about:journey-step-ai') },
  { icon: 'cloud', label: t('about:journey-step-devops') },
];
---

<MainLayout {...seo}>
  <PageHeader
    badge={t('about:header-badge')}
    title={t('about:header-title')}
    subtitle={t('about:header-subtitle')}
  />

  <section class="section-spacing section-bg-primary">
    <div class="max-w-6xl mx-auto flex flex-col gap-10 md:gap-12 xl:gap-16">
      <AboutHero
        name={profile.name}
        role={profile.role}
        title={t('about:hero-title')}
        subtitle={t('about:hero-subtitle')}
        specializations={heroSpecializations}
        logoDarkSrc={isotipoDark.src}
        logoLightSrc={isotipoLight.src}
        logoDarkWidth={isotipoDark.width}
        logoDarkHeight={isotipoDark.height}
        logoLightWidth={isotipoLight.width}
        logoLightHeight={isotipoLight.height}
      />

      <div class="grid grid-cols-1 xl:grid-cols-[minmax(0,1.3fr)_minmax(0,0.85fr)] gap-6 xl:gap-7 items-start">
        <div class="flex flex-col gap-8 md:gap-10">
          <AboutExecutiveSummary
            heading={t('about:executive-summary-heading')}
            paragraphs={executiveSummaryParagraphs}
          />

          <AboutFocusAreas heading={t('about:focus-areas-heading')} items={mappedFocusAreas} />
        </div>

        <AboutQuickInfoPanel
          heading={t('about:quick-info-heading')}
          infoItems={quickInfoItems}
          brandingLabel={t('about:quick-info-brand-label')}
          brandingTitle={profile.fullName}
          brandingSubtitle={profile.tagline}
          socialHeading={t('about:quick-info-social-heading')}
          socialLinks={socialLinks}
        />
      </div>

      <AboutProfessionalImpact
        heading={t('about:impact-heading')}
        subtitle={t('about:impact-subtitle')}
        items={impactItems}
      />

      <AboutCareerJourney
        heading={t('about:journey-heading')}
        subtitle={t('about:journey-subtitle')}
        steps={journeySteps}
      />

      <AboutProfessionalGoal
        heading={t('about:goal-heading')}
        description={t('about:goal-description')}
        closingLine={t('about:goal-closing-line')}
      />
    </div>
  </section>
</MainLayout>
