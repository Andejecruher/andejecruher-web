---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import BlogHero from '../../components/blog/BlogHero.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import BlogLayout from '../../components/blog/BlogLayout.astro';
import EmptyBlogState from '../../components/blog/EmptyBlogState.astro';
import { getLang, useTranslations } from '../../i18n/utils';
import { getPageSeo } from '../../seo/pages';

const isDev = import.meta.env.DEV;
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const seo = getPageSeo('blog', lang);

const allPosts = await getCollection('blog', ({ data }) => {
  return isDev ? true : !data.draft;
});

function toSlug(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

// Sort by pubDate descending
const posts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// Derive unique categories
const allCategories = [...new Set(posts.map((p) => p.data.category))];

// Fallback server-side filter (still works for non-JS environments / pre-renders)
const { searchParams } = Astro.url;
const activeCategory = searchParams.get('category') ?? 'all';

const filteredPosts =
  activeCategory === 'all' ? posts : posts.filter((p) => p.data.category === activeCategory);

// Serialise all posts to JSON for the client-side filter script
const postsJson = posts.map((p) => ({
  slug: toSlug(p.id),
  category: p.data.category,
}));
---

<MainLayout {...seo}>
  <BlogHero postCount={posts.length} />

  <BlogLayout>
    <!-- Category Filter -->
    {
      allCategories.length > 1 && (
        <div class="mb-10" id="category-filter">
          <p class="text-label mb-3">{t('blog:filters-label')}</p>
          <div class="flex flex-wrap gap-2" role="list" aria-label={t('blog:filters-aria-label')}>
            <button
              data-category="all"
              role="listitem"
              class="category-btn chip-filter chip-filter-active"
            >
              {t('blog:filters-all')}
            </button>
            {allCategories.map((cat) => (
              <button data-category={cat} role="listitem" class="category-btn chip-filter">
                {cat}
              </button>
            ))}
          </div>
        </div>
      )
    }

    <!-- Posts grid — all posts rendered; JS hides/shows cards -->
    <div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        posts.map((post, i) => (
          <div data-post-category={post.data.category} class="post-card-wrapper">
            <BlogCard
              slug={toSlug(post.id)}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              tags={post.data.tags}
              image={post.data.image}
              readingTime={post.data.readingTime}
              index={i}
            />
          </div>
        ))
      }
    </div>

    <!-- Empty state — shown by JS when no cards match filter -->
    <div id="empty-state" class="hidden">
      <EmptyBlogState />
    </div>
  </BlogLayout>
</MainLayout>

<!--
  Client-side category filter.
  Works on static output without a server or React.
  Falls back gracefully: if JS is disabled, ALL posts remain visible.
  URL param (?category=) is also honoured on load.
-->
<script define:vars={{ allCategories, postsJson }}>
  (function () {
    function getCategoryFromURL() {
      try {
        return new URL(window.location.href).searchParams.get('category') || 'all';
      } catch (_) {
        return 'all';
      }
    }

    let active = getCategoryFromURL();

    function filterPosts(category) {
      const wrappers = document.querySelectorAll('.post-card-wrapper');
      let visibleCount = 0;

      wrappers.forEach((wrapper) => {
        const cat = wrapper.getAttribute('data-post-category');
        const show = category === 'all' || cat === category;
        wrapper.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });

      const emptyState = document.getElementById('empty-state');
      if (emptyState) {
        emptyState.classList.toggle('hidden', visibleCount > 0);
      }
    }

    function updateButtons(category) {
      document.querySelectorAll('.category-btn').forEach((btn) => {
        const isActive = btn.getAttribute('data-category') === category;
        if (isActive) {
          btn.classList.remove('chip-filter');
          btn.classList.add('chip-filter-active');
        } else {
          btn.classList.remove('chip-filter-active');
          btn.classList.add('chip-filter');
        }
      });
    }

    function updateURL(category) {
      try {
        const url = new URL(window.location.href);
        if (category === 'all') {
          url.searchParams.delete('category');
        } else {
          url.searchParams.set('category', category);
        }
        history.replaceState({}, '', url.toString());
      } catch (_) {}
    }

    function setCategory(category) {
      active = category;
      filterPosts(category);
      updateButtons(category);
      updateURL(category);
    }

    document.querySelectorAll('.category-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        setCategory(btn.getAttribute('data-category') || 'all');
      });
    });

    setCategory(active);
  })();
</script>
