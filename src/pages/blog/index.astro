---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import BlogHero from '../../components/blog/BlogHero.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import EmptyBlogState from '../../components/blog/EmptyBlogState.astro';

const isDev = import.meta.env.DEV;

const allPosts = await getCollection('blog', ({ data }) => {
  return isDev ? true : !data.draft;
});

function toSlug(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}
// Sort by pubDate descending
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

// Derive unique categories
const allCategories = [...new Set(posts.map((p) => p.data.category))];

// Active category filter (URL param)
const { searchParams } = Astro.url;
const activeCategory = searchParams.get('category') ?? 'all';

const filteredPosts = activeCategory === 'all'
  ? posts
  : posts.filter((p) => p.data.category === activeCategory);
---

<MainLayout
  title="Blog"
  description="Blog técnico de Andejecruher — artículos sobre Full Stack Development, Laravel, Node.js, Python, AI Agents, SaaS y DevOps."
>
  <BlogHero postCount={posts.length} />

  <section class="py-16 px-4" style="background: var(--bg-primary);">
    <div class="max-w-6xl mx-auto">

      <!-- Category Filter -->
      {allCategories.length > 1 && (
        <div class="mb-10">
          <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--text-muted); font-family: var(--font-heading);">
            Filtrar por categoría
          </p>
          <div class="flex flex-wrap gap-2">
            <a
              href="/blog"
              class={`px-3 py-1.5 rounded-lg text-xs font-mono transition-all duration-200 ${activeCategory === 'all' ? 'text-cyan-400' : 'hover:border-cyan-400/40'}`}
              style={activeCategory === 'all'
                ? 'background: rgba(34,211,238,0.1); border: 1px solid rgba(34,211,238,0.35); color: var(--cyan-main);'
                : 'background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); color: var(--text-secondary);'}
            >
              Todos
            </a>
            {allCategories.map((cat) => (
              <a
                href={`/blog?category=${encodeURIComponent(cat)}`}
                class="px-3 py-1.5 rounded-lg text-xs font-mono transition-all duration-200"
                style={activeCategory === cat
                  ? 'background: rgba(34,211,238,0.1); border: 1px solid rgba(34,211,238,0.35); color: var(--cyan-main);'
                  : 'background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); color: var(--text-secondary);'}
              >
                {cat}
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Posts grid -->
      {filteredPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {filteredPosts.map((post, i) => (
            <BlogCard
              slug={toSlug(post.id)}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              tags={post.data.tags}
              image={post.data.image}
              readingTime={post.data.readingTime}
              index={i}
            />
          ))}
        </div>
      ) : (
        <EmptyBlogState />
      )}

    </div>
  </section>
</MainLayout>
