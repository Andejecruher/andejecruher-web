---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/MainLayout.astro';
import BlogHero from '../../components/blog/BlogHero.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import BlogLayout from '../../components/blog/BlogLayout.astro';
import EmptyBlogState from '../../components/blog/EmptyBlogState.astro';
import { getLang, useTranslations } from '../../i18n/utils';
import { getPageSeo } from '../../seo/pages';

const isDev = import.meta.env.DEV;
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const seo = getPageSeo('blog', lang);

const allPosts = await getCollection('blog', ({ data }) => {
  return isDev ? true : !data.draft;
});

function toSlug(id: string): string {
  return id.replace(/\.[^.]+$/, '');
}

// Sort by pubDate descending
const posts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// Derive unique categories
const allCategories = [...new Set(posts.map((p) => p.data.category))];

// Fallback server-side filter (still works for non-JS environments / pre-renders)
const { searchParams } = Astro.url;
const activeCategory = searchParams.get('category') ?? 'all';

const filteredPosts =
  activeCategory === 'all' ? posts : posts.filter((p) => p.data.category === activeCategory);

---

<MainLayout {...seo}>
  <BlogHero postCount={posts.length} />

  <BlogLayout>
    <!-- Category Filter -->
    {
      allCategories.length > 1 && (
        <div class="mb-10" id="category-filter">
          <p class="text-label mb-3">{t('blog:filters-label')}</p>
          <div class="flex flex-wrap gap-2" role="list" aria-label={t('blog:filters-aria-label')}>
            <button
              data-category="all"
              role="listitem"
              class="category-btn chip-filter chip-filter-active"
            >
              {t('blog:filters-all')}
            </button>
            {allCategories.map((cat) => (
              <button data-category={cat} role="listitem" class="category-btn chip-filter">
                {cat}
              </button>
            ))}
          </div>
        </div>
      )
    }

    <!-- Posts grid — all posts rendered; JS hides/shows cards -->
    <div id="posts-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        posts.map((post, i) => (
          <div data-post-category={post.data.category} class="post-card-wrapper">
            <BlogCard
              slug={toSlug(post.id)}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              tags={post.data.tags}
              image={post.data.image}
              readingTime={post.data.readingTime}
              index={i}
            />
          </div>
        ))
      }
    </div>

    <!-- Empty state — shown by JS when no cards match filter -->
    <div id="empty-state" class="hidden">
      <EmptyBlogState />
    </div>
  </BlogLayout>
</MainLayout>

<!--
  Client-side category filter.
  Works on static output without a server or React.
  Falls back gracefully: if JS is disabled, ALL posts remain visible.
  URL param (?category=) is also honoured on load.
-->
<script define:vars={{ allCategories }}>
  (function () {
    const APP_SCOPE = 'blog-category-filter';
    const CLEANUP_KEY = '__blogCategoryFilterCleanup__';

    function normalizeCategory(value) {
      const normalized = (value || 'all').trim();
      if (normalized === 'all') return 'all';
      return allCategories.includes(normalized) ? normalized : 'all';
    }

    function getCategoryFromURL() {
      try {
        return normalizeCategory(new URL(window.location.href).searchParams.get('category') || 'all');
      } catch (_) {
        return 'all';
      }
    }

    function initBlogFilter() {
      if (typeof window[CLEANUP_KEY] === 'function') {
        window[CLEANUP_KEY]();
      }

      const filterRoot = document.getElementById('category-filter');
      if (!filterRoot) {
        return;
      }

      const controller = new AbortController();
      const { signal } = controller;
      window[CLEANUP_KEY] = () => controller.abort();

      const wrappers = Array.from(document.querySelectorAll('.post-card-wrapper'));
      const buttons = Array.from(document.querySelectorAll('.category-btn'));
      const emptyState = document.getElementById('empty-state');

      const render = (category) => {
        const normalizedCategory = normalizeCategory(category);
        let visibleCount = 0;

        wrappers.forEach((wrapper) => {
          const cardCategory = wrapper.getAttribute('data-post-category');
          const show = normalizedCategory === 'all' || cardCategory === normalizedCategory;
          wrapper.style.display = show ? '' : 'none';
          if (show) visibleCount += 1;
        });

        if (emptyState) {
          emptyState.classList.toggle('hidden', visibleCount > 0);
        }

        buttons.forEach((button) => {
          const isActive = normalizeCategory(button.getAttribute('data-category') || 'all') === normalizedCategory;
          button.classList.toggle('chip-filter-active', isActive);
          button.classList.toggle('chip-filter', !isActive);
        });

        try {
          const url = new URL(window.location.href);
          if (normalizedCategory === 'all') {
            url.searchParams.delete('category');
          } else {
            url.searchParams.set('category', normalizedCategory);
          }
          history.replaceState({ scope: APP_SCOPE, category: normalizedCategory }, '', url);
        } catch (_) {}
      };

      buttons.forEach((button) => {
        button.addEventListener(
          'click',
          () => {
            render(button.getAttribute('data-category') || 'all');
          },
          { signal },
        );
      });

      window.addEventListener(
        'popstate',
        () => {
          render(getCategoryFromURL());
        },
        { signal },
      );

      render(getCategoryFromURL());
    }

    initBlogFilter();
    document.addEventListener('astro:page-load', initBlogFilter);
  })();
</script>
