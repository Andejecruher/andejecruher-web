---
import { getCollection, render } from 'astro:content';
import BlogMeta from '../../components/blog/BlogMeta.astro';
import BlogTags from '../../components/blog/BlogTags.astro';
import RelatedPosts from '../../components/blog/RelatedPosts.astro';
import TableOfContents from '../../components/blog/TableOfContents.astro';
import { localizePath } from '../../i18n/routing';
import { getLang, useTranslations } from '../../i18n/utils';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    return data.status === 'published';
  });
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.[^.]+$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const slug = post.id.replace(/\.[^.]+$/, '');
const { Content, headings } = await render(post);
const readingTime = post.data.readingTime;

// Related posts prioritize shared category and tags
const allPosts = await getCollection('blog', ({ data }) =>
  data.status === 'published',
);
const related = allPosts
  .filter((p) => p.id.replace(/\.[^.]+$/, '') !== slug && (p.data.category === post.data.category || p.data.tags.some((tag) => post.data.tags.includes(tag))))
  .sort((a, b) => Number(b.data.category === post.data.category) - Number(a.data.category === post.data.category) || b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const chronological = [...allPosts].sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const currentIndex = chronological.findIndex((item) => item.id === post.id);
const previousPost = chronological[currentIndex + 1];
const nextPost = chronological[currentIndex - 1];

const homeHref = localizePath('/', lang);
const blogHref = localizePath('/blog', lang);
const contactHref = localizePath('/contacto', lang);
---

<BlogPostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  author={post.data.author}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  tags={post.data.tags}
  category={post.data.category}
>
  <!-- Hero / header -->
  <section class="relative pt-10 pb-8 px-4 overflow-hidden section-bg-page-header">
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-48 opacity-[0.1] pointer-events-none glow-radial-subtle"
      aria-hidden="true"
    >
    </div>

    <div class="max-w-3xl mx-auto relative z-10">
      <nav
        class="flex items-center gap-2 text-xs font-mono mb-8 text-body-muted"
        aria-label={t('blog:breadcrumb-aria-label')}
      >
        <a href={homeHref} class="link-muted">{t('blog:breadcrumb-home')}</a>
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M9 18l6-6-6-6"></path>
        </svg>
        <a href={blogHref} class="link-muted">{t('blog:breadcrumb-blog')}</a>
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M9 18l6-6-6-6"></path>
        </svg>
        <span class="truncate max-w-48 text-body-secondary">{post.data.title}</span>
      </nav>

      <BlogMeta
        category={post.data.category}
        pubDate={post.data.pubDate}
        updatedDate={post.data.updatedDate}
        readingTime={readingTime}
        author={post.data.author}
      />

      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-balance mt-4 mb-4 text-heading">
        {post.data.title}
      </h1>

      <p class="text-base md:text-lg leading-relaxed mb-6 text-body-secondary">
        {post.data.description}
      </p>

      <BlogTags tags={post.data.tags} />
    </div>
  </section>

  {
    post.data.image && (
      <div class="px-4 max-w-3xl mx-auto mt-8">
        <img
          src={post.data.image}
          alt={post.data.imageAlt}
          width="896"
          height="504"
          class="article-featured-image w-full rounded-2xl object-cover border divider"
          loading="eager"
        />
      </div>
    )
  }

  <!-- Content + ToC layout -->
  <div class="py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <details class="lg:hidden glass-card rounded-xl p-4 mb-8"><summary class="font-semibold text-heading cursor-pointer">{t('blog:toc-title')}</summary><div class="mt-4"><TableOfContents headings={headings} /></div></details>
      <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_280px] lg:gap-12 items-start">
        <!-- Article body -->
        <article class="prose-blog max-w-3xl w-full">
          <Content />
        </article>

        <!-- Sidebar: ToC -->
        <aside class="hidden lg:block sticky top-24">
          <TableOfContents headings={headings} />
        </aside>
      </div>
    </div>
  </div>

  <!-- Post footer -->
  <section class="px-4 pb-12">
    <div class="max-w-3xl mx-auto">
      <!-- Tags -->
      <div class="mb-8">
        <p class="text-label mb-3">{t('blog:post-tags-label')}</p>
        <BlogTags tags={post.data.tags} />
      </div>

      <nav class="post-navigation grid sm:grid-cols-2 gap-4 mb-10" aria-label={t('blog:post-navigation-label')}>
        {previousPost && <a class="glass-card rounded-xl p-4 link-heading" href={localizePath(`/blog/${previousPost.id.replace(/\.[^.]+$/, '')}`, lang)}><span class="text-label block mb-2">← {t('blog:previous-post')}</span><strong>{previousPost.data.title}</strong></a>}
        {nextPost && <a class="glass-card rounded-xl p-4 link-heading sm:text-right sm:col-start-2" href={localizePath(`/blog/${nextPost.id.replace(/\.[^.]+$/, '')}`, lang)}><span class="text-label block mb-2">{t('blog:next-post')} →</span><strong>{nextPost.data.title}</strong></a>}
      </nav>

      <a
        href={blogHref}
        class="inline-flex items-center gap-2 text-sm font-semibold link-accent mb-12"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path d="M19 12H5M12 5l-7 7 7 7"></path>
        </svg>
        {t('blog:post-back-to-blog')}
      </a>
    </div>
  </section>

  <!-- Related posts -->
  {
    related.length > 0 && (
      <section class="px-4 pb-16">
        <div class="max-w-6xl mx-auto">
          <RelatedPosts
            posts={related.map((p) => ({
              slug: p.id.replace(/\.[^.]+$/, ''),
              data: {
                title: p.data.title,
                description: p.data.description,
                pubDate: p.data.pubDate,
                category: p.data.category,
                tags: p.data.tags,
                image: p.data.image,
                imageAlt: p.data.imageAlt,
                readingTime: p.data.readingTime,
              },
            }))}
          />
        </div>
      </section>
    )
  }

  <section class="px-4 pb-20">
    <div class="max-w-3xl mx-auto">
      <div class="panel-accent p-8 text-center">
        <h2 class="text-xl font-semibold mb-3 text-heading">{t('blog:post-cta-title')}</h2>
        <p class="text-sm leading-relaxed mb-6 max-w-md mx-auto text-body-secondary">
          {t('blog:post-cta-body')}
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href={contactHref} class="btn btn-primary btn-sm">
            {t('blog:post-cta-primary')}
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
            >
              <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
          </a>
          <a href={blogHref} class="btn btn-secondary btn-sm">
            {t('blog:post-cta-secondary')}
          </a>
        </div>
      </div>
    </div>
  </section>
</BlogPostLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLElement>('.prose-blog pre').forEach((pre) => {
      if (pre.querySelector('.copy-code-button')) return;
      const button = document.createElement('button'); button.type = 'button'; button.className = 'copy-code-button'; button.textContent = document.documentElement.lang === 'en' ? 'Copy' : 'Copiar';
      button.addEventListener('click', async () => { await navigator.clipboard.writeText(pre.querySelector('code')?.textContent ?? ''); button.textContent = document.documentElement.lang === 'en' ? 'Copied' : 'Copiado'; setTimeout(() => button.textContent = document.documentElement.lang === 'en' ? 'Copy' : 'Copiar', 1600); });
      pre.append(button);
    });
  });
</script>
