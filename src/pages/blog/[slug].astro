---
import { getCollection, render } from 'astro:content';
import BlogMeta from '../../components/blog/BlogMeta.astro';
import BlogTags from '../../components/blog/BlogTags.astro';
import RelatedPosts from '../../components/blog/RelatedPosts.astro';
import TableOfContents from '../../components/blog/TableOfContents.astro';
import { localizePath } from '../../i18n/routing';
import { getLang, useTranslations } from '../../i18n/utils';
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => {
    return import.meta.env.DEV ? true : !data.draft;
  });
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.[^.]+$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const slug = post.id.replace(/\.[^.]+$/, '');
const { Content, headings, remarkPluginFrontmatter } = await render(post);

// Auto-compute reading time if not in frontmatter
const readingTime = post.data.readingTime ?? remarkPluginFrontmatter?.readingTime ?? 5;

// Related posts: same category, exclude current
const allPosts = await getCollection('blog', ({ data }) =>
  import.meta.env.DEV ? true : !data.draft,
);
const related = allPosts
  .filter((p) => p.id.replace(/\.[^.]+$/, '') !== slug && p.data.category === post.data.category)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const homeHref = localizePath('/', lang);
const blogHref = localizePath('/blog', lang);
const contactHref = localizePath('/contacto', lang);
---

<BlogPostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  author={post.data.author}
  image={post.data.image}
  tags={post.data.tags}
  category={post.data.category}
>
  <!-- Hero / header -->
  <section class="relative pt-10 pb-8 px-4 overflow-hidden section-bg-page-header">
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-48 opacity-15 pointer-events-none glow-radial-subtle"
      aria-hidden="true"
    >
    </div>

    <div class="max-w-3xl mx-auto relative z-10">
      <nav
        class="flex items-center gap-2 text-xs font-mono mb-8 text-body-muted"
        aria-label={t('blog:breadcrumb-aria-label')}
      >
        <a href={homeHref} class="link-muted hover:text-brand-primary"
          >{t('blog:breadcrumb-home')}</a
        >
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M9 18l6-6-6-6"></path>
        </svg>
        <a href={blogHref} class="link-muted hover:text-brand-primary"
          >{t('blog:breadcrumb-blog')}</a
        >
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M9 18l6-6-6-6"></path>
        </svg>
        <span class="truncate max-w-48 text-body-secondary">{post.data.title}</span>
      </nav>

      <BlogMeta
        category={post.data.category}
        pubDate={post.data.pubDate}
        updatedDate={post.data.updatedDate}
        readingTime={readingTime}
        author={post.data.author}
      />

      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-balance mt-4 mb-4 text-heading">
        {post.data.title}
      </h1>

      <p class="text-base md:text-lg leading-relaxed mb-6 text-body-secondary">
        {post.data.description}
      </p>

      <BlogTags tags={post.data.tags} />
    </div>
  </section>

  {
    post.data.image && (
      <div class="px-4 max-w-3xl mx-auto mt-8">
        <img
          src={post.data.image}
          alt={post.data.title}
          width="896"
          height="504"
          class="w-full rounded-2xl object-cover border border-[var(--color-border)]"
          loading="eager"
        />
      </div>
    )
  }

  <!-- Content + ToC layout -->
  <div class="py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="lg:grid lg:grid-cols-[1fr_260px] lg:gap-12 items-start">
        <!-- Article body -->
        <article class="prose-blog max-w-3xl w-full">
          <Content />
        </article>

        <!-- Sidebar: ToC -->
        <aside class="hidden lg:block sticky top-24">
          <TableOfContents headings={headings} />
        </aside>
      </div>
    </div>
  </div>

  <!-- Post footer -->
  <section class="px-4 pb-12">
    <div class="max-w-3xl mx-auto">
      <!-- Tags -->
      <div class="mb-8">
        <p class="text-label mb-3">{t('blog:post-tags-label')}</p>
        <BlogTags tags={post.data.tags} />
      </div>

      <a
        href={blogHref}
        class="inline-flex items-center gap-2 text-sm font-semibold link-accent mb-12"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path d="M19 12H5M12 5l-7 7 7 7"></path>
        </svg>
        {t('blog:post-back-to-blog')}
      </a>
    </div>
  </section>

  <!-- Related posts -->
  {
    related.length > 0 && (
      <section class="px-4 pb-16">
        <div class="max-w-6xl mx-auto">
          <RelatedPosts
            posts={related.map((p) => ({
              slug: p.id.replace(/\.[^.]+$/, ''),
              data: {
                title: p.data.title,
                description: p.data.description,
                pubDate: p.data.pubDate,
                category: p.data.category,
                tags: p.data.tags,
                image: p.data.image,
                readingTime: p.data.readingTime,
              },
            }))}
          />
        </div>
      </section>
    )
  }

  <section class="px-4 pb-20">
    <div class="max-w-3xl mx-auto">
      <div class="panel-accent p-8 text-center">
        <h2 class="text-xl font-semibold mb-3 text-heading">{t('blog:post-cta-title')}</h2>
        <p class="text-sm leading-relaxed mb-6 max-w-md mx-auto text-body-secondary">
          {t('blog:post-cta-body')}
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href={contactHref} class="btn btn-primary btn-sm">
            {t('blog:post-cta-primary')}
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
            >
              <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
          </a>
          <a href={blogHref} class="btn btn-secondary btn-sm">
            {t('blog:post-cta-secondary')}
          </a>
        </div>
      </div>
    </div>
  </section>
</BlogPostLayout>
