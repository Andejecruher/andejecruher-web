---
import ContactCTA from '../components/sections/home/ContactCTA.astro';
import ExperiencePreview from '../components/sections/home/ExperiencePreview.astro';
import FeaturedProjects from '../components/sections/home/FeaturedProjects.astro';
import Hero from '../components/sections/home/Hero.astro';
import StackPreview from '../components/sections/home/StackPreview.astro';
import MainLayout from '../layouts/MainLayout.astro';
import { getLang } from '../i18n/utils';
import { getPageSeo } from '../seo/pages';

const lang = getLang(Astro.url.pathname);
const seo = getPageSeo('home', lang);
---

<MainLayout {...seo}>
  <Hero />
  <ExperiencePreview />
  <FeaturedProjects />
  <StackPreview />
  <ContactCTA />
</MainLayout>
