---
import { getProjectBySlug, getProjects, statusColors } from '../../data/projects';
import { localizePath } from '../../i18n/routing';
import { getLang, useTranslations } from '../../i18n/utils';
import MainLayout from '../../layouts/MainLayout.astro';
import { seoFromProject } from '../../seo/utils';

export function getStaticPaths() {
  return getProjects('es').map((project) => ({
    params: { slug: project.slug },
  }));
}
const slug = Astro.params.slug ?? '';
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const project = getProjectBySlug(slug, lang);

if (!project) {
  return Astro.redirect(localizePath('/proyectos', lang));
}

const categoryLabel = t(`projects:category-${project.categoryKey}`);
const homeHref = localizePath('/', lang);
const projectsHref = localizePath('/proyectos', lang);
const seo = seoFromProject({
  name: project.name,
  description: project.description,
  slug: project.slug,
  tags: project.tags,
  section: categoryLabel,
  image: project.image,
  lang,
});
---

<MainLayout {...seo}>
  <section class="relative pt-10 pb-8 px-4 overflow-hidden section-bg-secondary">
    <div class="max-w-4xl mx-auto relative z-10">
      <nav
        class="flex items-center gap-2 text-xs font-mono mb-8 text-body-muted"
        aria-label={t('projects:breadcrumb-aria-label')}
      >
        <a href={homeHref} class="link-muted">{t('nav:item-home')}</a>
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M9 18l6-6-6-6"></path>
        </svg>
        <a href={projectsHref} class="link-muted">{t('nav:item-projects')}</a>
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M9 18l6-6-6-6"></path>
        </svg>
        <span class="text-body-secondary truncate max-w-48">{project.name}</span>
      </nav>

      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="chip chip-accent">{categoryLabel}</span>
        <span class={`badge badge-neutral border ${statusColors[project.status]}`}>
          {t(`projects:status-${project.status}`)}
        </span>
      </div>

      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-heading mb-4">
        {project.name}
      </h1>

      <p class="text-base md:text-lg leading-relaxed text-body-secondary mb-6">
        {project.description}
      </p>

      <div class="flex flex-wrap gap-2 mb-8">
        {project.tags.map((tag) => <span class="chip-tech">#{tag}</span>)}
      </div>

      {
        project.image && (
          <img
            src={project.image}
            alt={project.name}
            width="896"
            height="504"
            class="w-full rounded-2xl object-cover mb-8 border divider"
            loading="eager"
          />
        )
      }
    </div>
  </section>

  <section class="py-12 px-4 section-bg-primary">
    <div class="max-w-4xl mx-auto flex flex-col gap-8">
      <div class="card p-6">
        <h2 class="text-label mb-3">{t('projects:problem-label')}</h2>
        <p class="text-sm leading-relaxed text-body-secondary">{project.problem}</p>
      </div>

      <div>
        <h2 class="text-label mb-3">{t('projects:role-label')}</h2>
        <p class="text-sm text-body-secondary">{project.role}</p>
      </div>

      <div>
        <h2 class="text-label mb-3">{t('projects:technologies-label')}</h2>
        <div class="flex flex-wrap gap-2">
          {project.technologies.map((tech) => <span class="chip-tech">{tech}</span>)}
        </div>
      </div>

      <div class="flex flex-wrap gap-4 pt-4 border-t divider">
        {
          project.links.demo ? (
            <a
              href={project.links.demo}
              class="btn btn-primary inline-flex items-center gap-2"
              target="_blank"
              rel="noopener noreferrer"
            >
              {t('projects:demo-label')}
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                aria-hidden="true"
              >
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3" />
              </svg>
            </a>
          ) : (
            <span class="text-sm text-body-muted">{t('projects:no-demo')}</span>
          )
        }
        {
          project.links.repo && (
            <a
              href={project.links.repo}
              class="btn btn-secondary inline-flex items-center gap-2"
              target="_blank"
              rel="noopener noreferrer"
            >
              {t('projects:repo-label')}
            </a>
          )
        }
        <a href={projectsHref} class="btn btn-secondary inline-flex items-center gap-2">
          {t('projects:back-to-projects')}
        </a>
      </div>
    </div>
  </section>
</MainLayout>
