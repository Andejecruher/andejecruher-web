---
import { getProjectBySlug, getProjects, statusColors } from '../../data/projects';
import ProjectMedia from '../../components/projects/ProjectMedia.astro';
import { localizePath } from '../../i18n/routing';
import { getLang, useTranslations } from '../../i18n/utils';
import MainLayout from '../../layouts/MainLayout.astro';
import { seoFromProject } from '../../seo/utils';

export function getStaticPaths() {
  return getProjects('es').map((project) => ({
    params: { slug: project.slug },
  }));
}
const slug = Astro.params.slug ?? '';
const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const project = getProjectBySlug(slug, lang);

if (!project) {
  return Astro.redirect(localizePath('/proyectos', lang));
}

const categoryLabel = t(`projects:category-${project.categoryKey}`);
const homeHref = localizePath('/', lang);
const projectsHref = localizePath('/proyectos', lang);
const seo = seoFromProject({
  name: project.name,
  description: project.description,
  slug: project.slug,
  tags: project.tags,
  section: categoryLabel,
  image: project.image,
  lang,
});
---

<MainLayout {...seo}>
  <section
    class="relative overflow-hidden section-bg-secondary px-4 pb-10 sm:pb-12"
    style="padding-top: calc(var(--site-header-height, 5rem) + clamp(1rem, 2.5vw, 1.75rem));"
  >
    <div class="max-w-4xl mx-auto relative z-10">
      <nav
        class="mb-6 flex flex-wrap items-center gap-x-2 gap-y-1.5 text-xs font-mono text-body-muted sm:mb-8"
        aria-label={t('projects:breadcrumb-aria-label')}
      >
        <a href={homeHref} class="link-muted">{t('nav:item-home')}</a>
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M9 18l6-6-6-6"></path>
        </svg>
        <a href={projectsHref} class="link-muted">{t('nav:item-projects')}</a>
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M9 18l6-6-6-6"></path>
        </svg>
        <span class="max-w-[12rem] truncate text-body-secondary sm:max-w-xs md:max-w-sm">{project.name}</span>
      </nav>

      <div class="mb-5 flex flex-wrap items-center gap-2.5">
        <span class="chip chip-accent">{categoryLabel}</span>
        <span class={`badge badge-neutral border ${statusColors[project.status]}`}>
          {t(`projects:status-${project.status}`)}
        </span>
      </div>

      <h1 class="mb-4 break-words text-3xl font-semibold leading-tight tracking-tight text-heading sm:mb-5 sm:text-4xl lg:text-5xl">
        {project.name}
      </h1>

      <p class="mb-7 max-w-3xl break-words text-base leading-7 text-body-secondary sm:leading-8 md:mb-8 md:text-lg">
        {project.description}
      </p>

      <div class="mb-9 flex flex-wrap gap-2 sm:mb-10">
        {project.tags.map((tag) => <span class="chip-tech break-words">#{tag}</span>)}
      </div>

      <ProjectMedia
        name={project.name}
        image={project.image}
        alt={`${project.name} project preview`}
        loading="eager"
        className="mb-6 sm:mb-8"
      />
    </div>
  </section>

  <section class="px-4 py-10 section-bg-primary sm:py-12">
    <div class="mx-auto flex max-w-4xl flex-col gap-8 sm:gap-10">
      <div class="card p-5 sm:p-7">
        <h2 class="text-label mb-3">{t('projects:problem-label')}</h2>
        <p class="break-words text-sm leading-relaxed text-body-secondary sm:text-base">{project.problem}</p>
      </div>

      <div>
        <h2 class="text-label mb-3">{t('projects:role-label')}</h2>
        <p class="break-words text-sm leading-relaxed text-body-secondary sm:text-base">{project.role}</p>
      </div>

      <div>
        <h2 class="text-label mb-3">{t('projects:technologies-label')}</h2>
        <div class="flex flex-wrap gap-x-2 gap-y-2.5">
          {project.technologies.map((tech) => <span class="chip-tech break-words">{tech}</span>)}
        </div>
      </div>

      <div class="mt-1 flex flex-wrap items-stretch gap-2.5 border-t pt-5 divider sm:mt-2 sm:items-center sm:gap-3">
        {
          project.links.demo ? (
            <a
              href={project.links.demo}
              class="btn btn-primary inline-flex w-full items-center justify-center gap-2 sm:min-w-[10.5rem] sm:w-auto"
              target="_blank"
              rel="noopener noreferrer"
            >
              {t('projects:demo-label')}
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                aria-hidden="true"
              >
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3" />
              </svg>
            </a>
          ) : (
            <span class="w-full text-sm text-body-muted sm:w-auto">{t('projects:no-demo')}</span>
          )
        }
        {
          project.links.repo && (
            <a
              href={project.links.repo}
              class="btn btn-secondary inline-flex w-full items-center justify-center gap-2 sm:min-w-[10.5rem] sm:w-auto"
              target="_blank"
              rel="noopener noreferrer"
            >
              {t('projects:repo-label')}
            </a>
          )
        }
        <a href={projectsHref} class="btn btn-ghost inline-flex w-full items-center justify-center gap-2 sm:ml-auto sm:min-w-[10.5rem] sm:w-auto">
          {t('projects:back-to-projects')}
        </a>
      </div>
    </div>
  </section>
</MainLayout>
