---
import MainLayout from '../../layouts/MainLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import ProjectCard from '../../components/projects/ProjectCard.astro';
import { getProjects } from '../../data/projects';
import { getLang, useTranslations } from '../../i18n/utils';
import { getPageSeo } from '../../seo/pages';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const projects = getProjects(lang);
const seo = getPageSeo('projects', lang);

const TAG_ALIASES: Record<string, string> = {
  ia: 'ai',
};

const normalizeTag = (value: string): string => {
  const normalized = value
    .trim()
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[\s_]+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-+|-+$/g, '');

  return TAG_ALIASES[normalized] ?? normalized;
};

const filterOptions = [
  { label: t('projects:filter-tag-saas'), value: normalizeTag('SaaS') },
  { label: t('projects:filter-tag-laravel'), value: normalizeTag('Laravel') },
  { label: t('projects:filter-tag-nodejs'), value: normalizeTag('Node.js') },
  { label: t('projects:filter-tag-python'), value: normalizeTag('Python') },
  { label: t('projects:filter-tag-react'), value: normalizeTag('React') },
  { label: t('projects:filter-tag-astro'), value: normalizeTag('Astro') },
  { label: t('projects:filter-tag-ai'), value: normalizeTag(t('projects:filter-tag-ai')) },
] as const;
---

<MainLayout {...seo}>
  <PageHeader
    badge={t('projects:header-badge')}
    title={t('projects:header-title')}
    subtitle={t('projects:header-subtitle')}
  />

  <section class="section-spacing section-bg-primary">
    <div class="max-w-6xl mx-auto">
      <div
        class="mb-10 flex flex-wrap gap-2.5"
        role="group"
        aria-label={t('projects:filter-group-aria')}
      >
        <button class="filter-btn chip-filter chip-filter-active" data-filter="all">
          {t('projects:filter-all')}
        </button>
        {
          filterOptions.map(({ label, value }) => (
            <button class="filter-btn chip-filter" data-filter={value}>
              {label}
            </button>
          ))
        }
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="projects-grid">
        {
          projects.map((project) => (
            <ProjectCard
              project={project}
              variant="default"
              showImage={true}
              showProblem={true}
              showActions={true}
            />
          ))
        }
      </div>
    </div>
  </section>
</MainLayout>

<script>
  const TAG_ALIASES: Record<string, string> = {
    ia: 'ai',
  };

  const normalizeTag = (value: string): string => {
    const normalized = value
      .trim()
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/[\s_]+/g, '-')
      .replace(/-+/g, '-')
      .replace(/^-+|-+$/g, '');

    return TAG_ALIASES[normalized] ?? normalized;
  };

  const APP_SCOPE = 'projects-tag-filter';
  const CLEANUP_KEY = '__projectsTagFilterCleanup__';

  function getTagFromURL(availableTags: Set<string>) {
    try {
      const nextTag = normalizeTag(new URL(window.location.href).searchParams.get('tag') ?? 'all');
      return nextTag === 'all' || availableTags.has(nextTag) ? nextTag : 'all';
    } catch (_) {
      return 'all';
    }
  }

  function initProjectsFilter() {
    if (typeof window[CLEANUP_KEY] === 'function') {
      window[CLEANUP_KEY]();
    }

    const grid = document.getElementById('projects-grid');
    if (!(grid instanceof HTMLElement)) {
      return;
    }

    const controller = new AbortController();
    const { signal } = controller;
    window[CLEANUP_KEY] = () => controller.abort();

    const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.filter-btn'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.project-card'));

    if (buttons.length === 0 || cards.length === 0) {
      return;
    }

    const availableTags = new Set(buttons.map((button) => normalizeTag(button.dataset.filter ?? 'all')));

    const render = (selectedTag: string) => {
      const normalizedTag = selectedTag === 'all' ? 'all' : normalizeTag(selectedTag);
      const activeTag = normalizedTag === 'all' || availableTags.has(normalizedTag) ? normalizedTag : 'all';

      buttons.forEach((button) => {
        const buttonTag = normalizeTag(button.dataset.filter ?? 'all');
        const active = buttonTag === activeTag;
        button.classList.toggle('chip-filter-active', active);
        button.classList.toggle('chip-filter', !active);
      });

      cards.forEach((card) => {
        const cardTags = (card.dataset.tags ?? '')
          .split(',')
          .map((tag) => normalizeTag(tag))
          .filter((tag) => tag.length > 0);
        const show = activeTag === 'all' || cardTags.includes(activeTag);
        card.style.display = show ? 'flex' : 'none';
      });

      return activeTag;
    };

    const applyFromURL = () => {
      render(getTagFromURL(availableTags));
    };

    buttons.forEach((button) => {
      button.addEventListener(
        'click',
        () => {
          const activeTag = render(button.dataset.filter ?? 'all');

          try {
            const url = new URL(window.location.href);
            if (activeTag === 'all') {
              url.searchParams.delete('tag');
            } else {
              url.searchParams.set('tag', activeTag);
            }
            history.pushState({ scope: APP_SCOPE, tag: activeTag }, '', url);
          } catch (_) {}
        },
        { signal },
      );
    });

    window.addEventListener('popstate', applyFromURL, { signal });
    applyFromURL();
  }

  initProjectsFilter();
  document.addEventListener('astro:page-load', initProjectsFilter);
</script>
