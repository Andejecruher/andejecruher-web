---
import MainLayout from '../../layouts/MainLayout.astro';
import PageHeader from '../../components/ui/PageHeader.astro';
import ProjectCard from '../../components/projects/ProjectCard.astro';
import { getProjects } from '../../data/projects';
import { getLang, useTranslations } from '../../i18n/utils';
import { getPageSeo } from '../../seo/pages';

const lang = getLang(Astro.url.pathname);
const t = useTranslations(lang);
const projects = getProjects(lang);
const seo = getPageSeo('projects', lang);

const TAG_ALIASES: Record<string, string> = {
  ia: 'ai',
};

const normalizeTag = (value: string): string => {
  const normalized = value
    .trim()
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[\s_]+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-+|-+$/g, '');

  return TAG_ALIASES[normalized] ?? normalized;
};

const filterOptions = [
  { label: 'SaaS', value: normalizeTag('SaaS') },
  { label: 'Laravel', value: normalizeTag('Laravel') },
  { label: 'Node.js', value: normalizeTag('Node.js') },
  { label: 'React', value: normalizeTag('React') },
  { label: 'Astro', value: normalizeTag('Astro') },
  { label: 'IA', value: normalizeTag('IA') },
] as const;
---

<MainLayout {...seo}>
  <PageHeader
    badge={t('projects:header-badge')}
    title={t('projects:header-title')}
    subtitle={t('projects:header-subtitle')}
  />

  <section class="section-spacing section-bg-primary">
    <div class="max-w-6xl mx-auto">
      <div
        class="mb-10 flex flex-wrap gap-2.5"
        role="group"
        aria-label={t('projects:filter-group-aria')}
      >
        <button class="filter-btn chip-filter chip-filter-active" data-filter="all">
          {t('projects:filter-all')}
        </button>
        {
          filterOptions.map(({ label, value }) => (
            <button class="filter-btn chip-filter" data-filter={value}>
              {label}
            </button>
          ))
        }
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="projects-grid">
        {
          projects.map((project) => (
            <ProjectCard
              project={project}
              variant="default"
              showImage={true}
              showProblem={true}
              showActions={true}
            />
          ))
        }
      </div>
    </div>
  </section>
</MainLayout>

<script>
  const TAG_ALIASES: Record<string, string> = {
    ia: 'ai',
  };

  const normalizeTag = (value: string): string => {
    const normalized = value
      .trim()
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/[\s_]+/g, '-')
      .replace(/-+/g, '-')
      .replace(/^-+|-+$/g, '');

    return TAG_ALIASES[normalized] ?? normalized;
  };

  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const selectedFilter = normalizeTag(btn.dataset.filter ?? 'all');

      filterBtns.forEach((b) => {
        b.classList.remove('chip-filter-active');
        b.classList.add('chip-filter');
      });
      btn.classList.add('chip-filter-active');
      btn.classList.remove('chip-filter');

      cards.forEach((card) => {
        const cardTags = (card.dataset.tags ?? '')
          .split(',')
          .map((tag) => normalizeTag(tag))
          .filter((tag) => tag.length > 0);
        const show = selectedFilter === 'all' || cardTags.includes(selectedFilter);
        card.style.display = show ? 'flex' : 'none';
      });
    });
  });
</script>
